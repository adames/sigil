{
  "banner": [
    {
      "k": "caps",
      "v": "tap → Esc"
    },
    {
      "k": "caps + …",
      "v": "Hyper (⌃⌥⌘⇧)  ·  +shift = Mod"
    },
    {
      "k": "C-Space …",
      "v": "Tmux prefix"
    }
  ],
  "columns": [
    {
      "sections": [
        {
          "title": "Windows · Spaces",
          "rows": [
            [
              "caps + hjkl",
              "focus neighbour (tiled)  ·  snap h l = halves · j = center · k = fill (floating)"
            ],
            [
              "caps + shift + hjkl",
              "swap window  ←  ↓  ↑  →"
            ],
            [
              "caps + v",
              "toggle float (unfloat = snap to grid)"
            ],
            [
              "caps + r",
              "rotate space 90°"
            ],
            [
              "caps + n  ·  caps + p",
              "prev / next workspace (wraps)"
            ],
            [
              "caps + tab",
              "last / recent workspace"
            ]
          ],
          "family": "system",
          "sub": "yabai · skhd · ws-snap",
          "idea": "Hyper navigates; Mod modifies. Caps+hjkl is direction-aware — on a floating window it snaps (h/l = halves · j = center · k = fill); on a tiled window it focuses the neighbour. New windows arrive on the focused space + focused; floats are centered. Unfloat to commit, go to relocate, ⌘W to dismiss."
        },
        {
          "title": "Workspace Prompts",
          "rows": [
            [
              "caps + e",
              "change workspace → fuzzy-search every window in every space, ↵ jumps to its space"
            ],
            [
              "caps + f",
              "focus workspace → digit · letters → name search + ↵"
            ],
            [
              "caps + g  ·  caps + m",
              "go (send window) → digit (commit + follow) · letters + ↵"
            ],
            [
              "caps + w",
              "edit workspace → a add · r rename · i icon · d destroy"
            ],
            [
              "(in edit)",
              "⇧L layout save/load/delete · v verify · ? doctor"
            ],
            [
              "esc / click-elsewhere",
              "cancel any prompt"
            ],
            [
              "—",
              "names cannot start with a digit · all-numeric query = slot index (11+)"
            ]
          ],
          "family": "system",
          "sub": "four overlays · one pattern",
          "idea": "Four overlays, one pattern: digit commits · letters fuzzy-search · ↵ accepts · esc cancels. Pick by intent — change to jump to a window's space, focus to land on a space, go to send a window, edit to modify the space set."
        },
        {
          "title": "Launch",
          "rows": [
            [
              "caps + t",
              "new terminal"
            ],
            [
              "caps + b",
              "new browser"
            ],
            [
              "caps + o",
              "new Finder window"
            ],
            [
              "caps + ,",
              "System Settings"
            ],
            [
              "caps + q",
              "notes"
            ],
            [
              "caps + shift + q",
              "inbox"
            ],
            [
              "caps + ;",
              "this cheatsheet (toggle)"
            ]
          ],
          "family": "system",
          "sub": "skhd · auto-detected apps",
          "idea": "Each chord spawns a new window of an auto-detected app. Override the choice with $WS_* env vars."
        }
      ]
    },
    {
      "sections": [
        {
          "title": "Tmux",
          "rows": [
            [
              "C-Space  hjkl",
              "select pane  ←  ↓  ↑  →"
            ],
            [
              "C-Space  v / s",
              "split right / below  (mirrors vim C-w)"
            ],
            [
              "C-Space  | / -",
              "split right / below  (aliases)"
            ],
            [
              "C-Space  z",
              "zoom pane (toggle)"
            ],
            [
              "C-Space  d",
              "detach session"
            ],
            [
              "C-Space  r",
              "reload tmux.conf"
            ],
            [
              "C-Space  [",
              "copy / scroll mode  (q to exit)"
            ],
            [
              "C-Space  f",
              "sessionizer — fzf pick → switch/create session"
            ],
            [
              "C-Space  c",
              "new window"
            ],
            [
              "C-Space  n / p",
              "next / prev window"
            ],
            [
              "C-Space  0…9",
              "go to window N"
            ],
            [
              "C-Space  x",
              "kill pane  (no confirmation)"
            ],
            [
              "C-Space  &",
              "kill window  (no confirmation)"
            ],
            [
              "C-Space  $",
              "rename current session"
            ],
            [
              "C-Space  C-Space",
              "send literal C-Space to inner program (nvim cmp)"
            ]
          ],
          "family": "terminal",
          "sub": "prefix = C-Space",
          "idea": "C-Space is your prefix. Everything after it is one keystroke — pane, window, or session."
        },
        {
          "title": "Shell",
          "rows": [
            [
              "ctrl-r",
              "fzf history search"
            ],
            [
              "ctrl-t",
              "fzf file picker (insert path)"
            ],
            [
              "alt-c",
              "fzf cd into subdir"
            ],
            [
              "⟨pat⟩**<tab>",
              "fzf completion on the current word"
            ],
            [
              "esc",
              "enter vi-mode normal (then hjkl, /, w, b, …)"
            ],
            [
              "z ⟨pat⟩",
              "zoxide: jump to most-frecent matching dir"
            ],
            [
              "zi",
              "zoxide: interactive picker"
            ],
            [
              "rg ⟨pat⟩",
              "ripgrep — uses ~/.ripgreprc defaults"
            ],
            [
              "fd ⟨pat⟩",
              "fd — fast find replacement"
            ],
            [
              "direnv allow",
              "trust this dir's .envrc on first entry"
            ]
          ],
          "family": "terminal",
          "sub": "zsh · vi mode · fzf · zoxide",
          "idea": "fzf, zoxide and vi-mode turn the shell into a navigable surface, not a typewriter."
        }
      ]
    },
    {
      "sections": [
        {
          "title": "Vim · Motion",
          "rows": [
            [
              "0  ^  $",
              "line: start / first nonblank / end"
            ],
            [
              "gg  G",
              "file: top / bottom"
            ],
            [
              "{  }",
              "paragraph: back / forward"
            ],
            [
              "f / F  ·  t / T",
              "find / till char in line  ·  uppercase = backwards"
            ],
            [
              "%",
              "matching ( [ {"
            ],
            [
              "/pat   n / N",
              "search forward · next / prev match"
            ],
