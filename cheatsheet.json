            [
              "p  P",
              "paste: after / before"
            ],
            [
              "u   ctrl-r",
              "undo / redo"
            ],
            [
              ".",
              "repeat last change"
            ],
            [
              "ctrl-a  ctrl-x",
              "increment / decrement number"
            ],
            [
              "q⟨x⟩ … q     @⟨x⟩",
              "record macro to x / replay x"
            ],
            [
              ":%s/foo/bar/g",
              "replace all in buffer  (add c for confirm)"
            ]
          ],
          "family": "vim",
          "sub": "neovim · change & yank",
          "idea": "Verb + motion = composable change. The . key replays your last verb on the next thing."
        }
      ]
    }
  ]
}
