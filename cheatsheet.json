{
  "banner": [
    {
      "k": "caps",
      "v": "Hyper (⌃⌥⌘⇧) — navigate / open"
    },
    {
      "k": "caps + shift",
      "v": "Mod (⌃⌥⌘) — modify / destructive"
    },
    {
      "k": "C-a",
      "v": "tmux prefix"
    },
    {
      "k": "SPC",
      "v": "nvim leader"
    }
  ],
  "columns": [
    {
      "sections": []
    },
    {
      "sections": [
        {
          "title": "Tmux",
          "rows": [
            [
              "C-a  hjkl",
              "select pane  ←  ↓  ↑  →"
            ],
            [
              "C-a  v / s",
              "split right / below  (mirrors vim C-w)"
            ],
            [
              "C-a  | / -",
              "split right / below  (aliases)"
            ],
            [
              "C-a  z",
              "zoom pane (toggle)"
            ],
            [
              "C-a  d",
              "detach session"
            ],
            [
              "C-a  r",
              "reload tmux.conf"
            ],
            [
              "C-a  [",
              "copy / scroll mode  (q to exit)"
            ],
            [
              "C-a  f",
              "sessionizer — fzf pick → switch/create session"
            ],
            [
              "C-a  c",
              "new window"
            ],
            [
              "C-a  n / p",
              "next / prev window"
            ],
            [
              "C-a  0…9",
              "go to window N"
            ],
            [
              "C-a  x",
              "kill pane  (no confirmation)"
            ],
            [
              "C-a  &",
              "kill window  (no confirmation)"
            ],
            [
              "C-a  $",
              "rename current session"
            ],
            [
              "C-a  C-a",
              "send literal C-a to inner program (nvim cmp)"
            ]
          ],
          "family": "terminal",
          "sub": "prefix = C-a",
          "idea": "C-a is your prefix. Everything after it is one keystroke — pane, window, or session."
        },
        {
          "title": "Shell",
          "rows": [
            [
              "ctrl-r",
              "fzf history search"
            ],
            [
              "ctrl-t",
              "fzf file picker (insert path)"
            ],
            [
              "alt-c",
              "fzf cd into subdir"
            ],
            [
              "⟨pat⟩**<tab>",
              "fzf completion on the current word"
            ],
            [
              "esc",
              "enter vi-mode normal (then hjkl, /, w, b, …)"
            ],
            [
              "z ⟨pat⟩",
              "zoxide: jump to most-frecent matching dir"
            ],
            [
              "zi",
              "zoxide: interactive picker"
            ],
            [
              "rg ⟨pat⟩",
              "ripgrep — uses ~/.ripgreprc defaults"
            ],
            [
              "fd ⟨pat⟩",
              "fd — fast find replacement"
            ],
            [
              "direnv allow",
              "trust this dir's .envrc on first entry"
            ]
          ],
          "family": "terminal",
          "sub": "zsh · vi mode · fzf · zoxide",
          "idea": "fzf, zoxide and vi-mode turn the shell into a navigable surface, not a typewriter."
        }
      ]
    },
    {
      "sections": [
        {
          "title": "Vim · Motion",
          "rows": [
            [
              "0  ^  $",
              "line: start / first nonblank / end"
            ],
            [
              "gg  G",
              "file: top / bottom"
            ],
            [
              "{  }",
              "paragraph: back / forward"
            ],
            [
              "f / F  ·  t / T",
              "find / till char in line  ·  uppercase = backwards"
            ],
            [
              "%",
              "matching ( [ {"
            ],
            [
              "/pat   n / N",
              "search forward · next / prev match"
            ],
            [
              "*  #",
              "search word under cursor: fwd / back"
            ],
            [
              "ctrl-o  ctrl-i",
              "jumplist: back / forward"
            ],
            [
              "m⟨a-z⟩  '⟨a-z⟩",
              "set mark / jump to mark line"
            ]
          ],
          "family": "vim",
          "sub": "neovim · cursor & jumps",
          "idea": "Every motion is a noun. Pair it with a verb (c · d · y) to describe an edit.",
          "customLayout": "keyboard"
        },
        {
          "title": "Vim · Edit",
          "rows": [
            [
              "i  a   I  A",
              "insert: before / after / line-start / line-end"
            ],
            [
              "o  O",
              "open line: below / above"
            ],
            [
              "cc  dd  yy",
              "change / delete / yank whole line"
            ],
            [
              "ci⟨x⟩  ca⟨x⟩",
              "change inside / around  (\" ' ( [ { t p)"
            ],
            [
              "p  P",
              "paste: after / before"
            ],
            [
              "u   ctrl-r",
              "undo / redo"
            ],
            [
              ".",
              "repeat last change"
            ],
            [
              "ctrl-a  ctrl-x",
              "increment / decrement number"
            ],
            [
              "q⟨x⟩ … q     @⟨x⟩",
              "record macro to x / replay x"
            ],
            [
              ":%s/foo/bar/g",
              "replace all in buffer  (add c for confirm)"
            ]
          ],
          "family": "vim",
          "sub": "neovim · change & yank",
          "idea": "Verb + motion = composable change. The . key replays your last verb on the next thing."
        }
      ]
    }
  ]
}
