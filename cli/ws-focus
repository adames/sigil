#!/usr/bin/env bash
# ws-focus <SLOT|next|prev|last> — focus space N (or cycle).
# Called from ws-prompt's focus overlay (Caps+w → digit/name) AND
# directly from skhd's Caps+n / Caps+p / Caps+Tab chords for cycling +
# recent-space jump. yabai's `space --focus N` silently no-ops for
# nonexistent N (its stderr message never surfaces), which is the
# existing UX bug we're fixing.
set -u

target="${1:-}"
[[ -n "$target" ]] || {
  osascript -e 'display notification "ws-focus: missing slot arg" with title "ws"'
  exit 2
}

# `last`/`recent` — delegate to yabai's built-in recent-space tracking.
# We don't try to pre-resolve which slot "recent" maps to (yabai owns
# that state) — so the optimistic sketchybar pre-paint isn't possible
# here. Trigger a plain workspace_changed afterward so the bar repaints
# from yabai's new state.
if [[ "$target" == "last" || "$target" == "recent" ]]; then
  if yabai -m space --focus recent 2>/dev/null; then
    command -v sketchybar >/dev/null 2>&1 \
      && sketchybar --trigger workspace_changed >/dev/null 2>&1 || true
    exit 0
  fi
  osascript -e 'display notification "yabai has no recent space yet" with title "ws"'
  exit 1
fi

# One yabai RPC. Three values when `target` is a literal slot
# (count + target_display + cur_sid); two when it's `next`/`prev`
# (target_display gets resolved after we compute the target index).
read -r count cur_sid target_disp < <(
  yabai -m query --spaces 2>/dev/null \
    | jq -r --arg t "$target" '
        [ length,
          ([.[] | select(."has-focus") | .index] | first // 0),
          ([.[] | select((.index|tostring) == $t) | .display] | first // empty)
        ] | @tsv
      ' 2>/dev/null
)
count="${count:-}"; cur_sid="${cur_sid:-}"; target_disp="${target_disp:-}"

if [[ -z "$count" || ! "$count" =~ ^[0-9]+$ ]]; then
  osascript -e 'display notification "yabai unavailable" with title "ws"'
  exit 1
fi

# Resolve next/prev → literal slot index. Modulo wrap so 0..N stays
# in-range and the last slot's `next` lands on slot 1 (and slot 1's
# `prev` lands on the last). Cur defaults to 1 if yabai didn't surface
# a focused space — the wrap math still produces a valid result.
case "$target" in
  next)
    cur="${cur_sid:-1}"; [[ "$cur" == "0" ]] && cur=1
    target=$(( cur % count + 1 ))
    target_disp=$(yabai -m query --spaces 2>/dev/null \
                  | jq -r --arg t "$target" \
                      '.[] | select((.index|tostring) == $t) | .display' 2>/dev/null)
    ;;
  prev)
    cur="${cur_sid:-1}"; [[ "$cur" == "0" ]] && cur=1
    target=$(( (cur - 2 + count) % count + 1 ))
    target_disp=$(yabai -m query --spaces 2>/dev/null \
                  | jq -r --arg t "$target" \
                      '.[] | select((.index|tostring) == $t) | .display' 2>/dev/null)
    ;;
esac

if [[ "$target" =~ ^[0-9]+$ ]] && (( target < 1 || target > count )); then
  osascript -e "display notification \"slot $target does not exist (have $count)\" with title \"ws\""
  exit 1
fi

# Optimistic pre-paint. Tell sketchybar the new active SID + OLD sid
# *before* yabai's transition lands, so the pill snaps the instant
# the chord commits. paint-all.sh has a minimal fast path (~15ms)
# triggered by the presence of both SIDs — it just touches the two
# pills that changed. The eventual space_changed cascade fires the
# full paint redundantly without env vars; states match, no flicker.
#
# Best-effort — sketchybar missing, or a target slot whose display
# yabai can't report, falls through to the legacy "wait for the
# cascade" timing with no UX regression.
if command -v sketchybar >/dev/null 2>&1 \
   && [[ -n "$target_disp" && -n "$cur_sid" && "$cur_sid" != "$target" ]]; then
  sketchybar --trigger workspace_changed \
    WS_OPTIMISTIC_SID="$target" \
    WS_OPTIMISTIC_OLD_SID="$cur_sid" \
    WS_OPTIMISTIC_DISPLAY="$target_disp" >/dev/null 2>&1 || true
fi

yabai -m space --focus "$target" 2>/dev/null || {
  # On failure restore correct state — re-trigger without the
  # optimistic env vars so paint-all.sh falls back to yabai's real
  # active SID.
  command -v sketchybar >/dev/null 2>&1 \
    && sketchybar --trigger workspace_changed >/dev/null 2>&1 || true
  osascript -e "display notification \"yabai focus failed for $target\" with title \"ws\""
  exit 1
}
