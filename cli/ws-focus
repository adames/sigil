#!/usr/bin/env bash
# ws-focus <SLOT|next|prev|last> — focus workspace N (or cycle).
# Called from ws-prompt's focus overlay (Caps+f → digit/name) AND
# directly from aerospace.toml's Caps+n / Caps+p / Caps+Tab bindings
# for cycling + back-and-forth.
set -u

target="${1:-}"
[[ -n "$target" ]] || {
  osascript -e 'display notification "ws-focus: missing slot arg" with title "ws"'
  exit 2
}

# `last`/`recent` → delegate to aerospace's built-in back-and-forth.
if [[ "$target" == "last" || "$target" == "recent" ]]; then
  if aerospace workspace-back-and-forth 2>/dev/null; then
    exit 0
  fi
  osascript -e 'display notification "no recent workspace yet" with title "ws"'
  exit 1
fi

# next/prev → delegate to aerospace's built-in cycle. --wrap-around
# makes the last workspace's "next" land back on the first.
if [[ "$target" == "next" || "$target" == "prev" ]]; then
  if aerospace workspace --wrap-around --no-stdin "$target" 2>/dev/null; then
    exit 0
  fi
  osascript -e "display notification \"aerospace workspace $target failed\" with title \"ws\""
  exit 1
fi

# Numeric slot → resolve to aerospace workspace name via list-workspaces.
# spaces.json composite-key order matches aerospace's monitor-grouped
# order under fork B, so the N-th entry is the chord target.
all=$(aerospace list-workspaces --all --json 2>/dev/null)
if [[ -z "$all" ]]; then
  osascript -e 'display notification "aerospace unavailable" with title "ws"'
  exit 1
fi
count=$(jq 'length' <<<"$all")
if [[ ! "$target" =~ ^[0-9]+$ ]] || (( target < 1 || target > count )); then
  osascript -e "display notification \"slot $target does not exist (have $count)\" with title \"ws\""
  exit 1
fi
name=$(jq -r --argjson n "$target" '.[$n - 1].workspace' <<<"$all")
[[ -z "$name" || "$name" == "null" ]] && {
  osascript -e "display notification \"slot $target has no workspace name\" with title \"ws\""
  exit 1
}

aerospace workspace "$name" 2>/dev/null || {
  osascript -e "display notification \"aerospace workspace $name failed\" with title \"ws\""
  exit 1
}
