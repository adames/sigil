#!/usr/bin/env bash
# ws — CLI for the per-display workspace pill strip. Mutates a workspace
# slot's identity (name / icon / color) and dispatches the cascade so
# every consumer (tmux, starship, borders, sketchybar) repaints in
# step. Formerly called `workspace`; the old name is kept as a compat
# symlink so older scripts and muscle-memory continue to work.
#
# Atomic spaces.json writes (mktemp + jq + normalize + mv), then on-space-changed.sh
# fires, then the optional ~/.config/workspace/hooks/post-mutate.sh runs
# as an extension point.
#
# Slot-count agnostic: every subcommand derives the current count from
# the JSON itself, not a hardcoded constant.
#
# Stable contract for callers:
#   exit codes  0 success · 1 runtime error · 2 usage error
#   env overrides  WS_CONFIG, WS_THEMES_DIR, WS_HANDLER, WS_HOOK
#   --json available on  status · get · themes
#
# Naming conventions (read this before adding new names):
#   • file-global names use the WS_* prefix and UPPER_SNAKE_CASE.
#       - Declared as  WS_X="${WS_X:-default}"  → user-overridable env knob.
#       - Declared as  WS_X='literal'  (often `readonly`) → internal
#         constant; callers should treat as immutable.
#   • file-private (within-function) names use lowercase snake_case;
#     transient staging files name themselves by purpose
#     (config_staging, layout_staging, defaults_staging) so a skim
#     reveals what's being written, not just that something is.
#   • functions: cmd_<subcommand>  → public CLI subcommand (1:1 with
#     `ws <subcommand>`). _<name>()  → file-private helper.
#   • boolean knobs phrase the toggle as English. Current set:
#     WS_SKIP_WM_SLOT_CHECK (test harness disables WM-derived bounds so
#     it can exercise JSON-only state). Default = 0. Legacy
#     WS_SKIP_YABAI_SLOT_CHECK is honored as an alias for back-compat.

set -u

# Source workspace configuration (bundle prefix, paths, window manager)
# This provides: WORKSPACE_BUNDLE_PREFIX, WORKSPACE_WINDOW_MANAGER, etc.
if [[ -r "$HOME/.config/workspace/lib/config.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/config.sh"
fi

# Source window manager abstraction layer
if [[ -r "$HOME/.config/workspace/lib/window-manager.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/window-manager.sh"
fi

# Resolve WS_CONFIG via the per-host overlay helper (falls back to the
# shared spaces.json when no host-specific file exists). Sourced before
# any other default-resolution so subsequent `${WS_CONFIG:-…}` defaults
# don't clobber the host overlay.
if [[ -r "$HOME/.config/workspace/lib/resolve-config.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/resolve-config.sh"
fi

WS_CONFIG="${WS_CONFIG:-$HOME/.config/workspace/spaces.json}"
WS_THEMES_DIR="${WS_THEMES_DIR:-$HOME/.config/workspace/themes}"
WS_HANDLER="${WS_HANDLER:-$HOME/.config/workspace/on-space-changed.sh}"
WS_HOOK="${WS_HOOK:-$HOME/.config/workspace/hooks/post-mutate.sh}"
WS_DEFAULTS="${WS_DEFAULTS:-$HOME/.config/workspace/spaces.default.json}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# Common helpers if available; tiny stubs otherwise so the CLI stays
# usable on machines without the dotfiles tree.
if [[ -r "$DOTFILES_DIR/lib/common.sh" ]]; then
  # shellcheck source=/dev/null
  . "$DOTFILES_DIR/lib/common.sh"
else
  ok()   { :; }
  step() { :; }
  info() { :; }
  err()  { printf 'ws: %s\n' "$*" >&2; }
  warn() { printf 'ws: %s\n' "$*" >&2; }
  have() { command -v "$1" >/dev/null 2>&1; }
fi

have() { command -v "$1" >/dev/null 2>&1; }   # ensure available regardless

# Shared helpers for codepoint unescape + hex→RGB. Stubs let the CLI keep
# working when the lib/ shipment hasn't landed (very fresh install).
if [[ -r "$HOME/.config/workspace/lib/icon-decode.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/icon-decode.sh"
else
  ws_decode_icon() { :; }
fi
if [[ -r "$HOME/.config/workspace/lib/hex-ansi.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/hex-ansi.sh"
else
  ws_hex_to_rgb() { printf '0 0 0\n'; }
fi

# ── helpers ─────────────────────────────────────────────────────────────

_require_config() {
  [[ -r "$WS_CONFIG" ]] || { err "spaces.json not found: $WS_CONFIG"; exit 1; }
  jq -e . "$WS_CONFIG" >/dev/null 2>&1 || { err "spaces.json is not valid JSON"; exit 1; }
}

_count() { jq '.spaces | keys | map(tonumber) | length' "$WS_CONFIG"; }

# Window manager's authoritative workspace count. 0 when aerospace is
# absent / daemon down / when WS_SKIP_WM_SLOT_CHECK=1 (the verify harness
# disables WM-derived bounds so it can exercise JSON-only state).
_wm_count() {
  [[ "${WS_SKIP_WM_SLOT_CHECK:-${WS_SKIP_YABAI_SLOT_CHECK:-0}}" == "1" ]] && { printf '0\n'; return; }
  if [[ -n "${WORKSPACE_WM_BIN:-}" ]]; then
    wm_space_count 2>/dev/null || printf '0\n'
  else
    printf '0\n'
  fi
}

# Addressable slot upper bound for CLI commands. Window manager owns existence —
# when it reports N spaces, slots 1..N are addressable even if some
# carry no JSON identity yet (identity writes lazy-seed). Falls back to
# JSON keys when WM is silent (Linux, harness). Never below _count
# (defensive: orphan JSON metadata stays addressable so the user can
# clean it up via `ws remove`).
_addressable_max() {
  local j w; j=$(_count); w=$(_wm_count)
  (( j > w )) && printf '%s\n' "$j" || printf '%s\n' "$w"
}

# Positional color from the factory defaults file, if it has one for this
# slot. Falls back to the catppuccin pastel `cmd_add` uses. Single source
# for both `cmd_add` and `_ensure_slot` so lazy-seeded slots look the
# same as user-added ones.
_default_color_for_slot() {
  local slot="$1" color=""
  if [[ -r "$WS_DEFAULTS" ]] && have jq; then
    color=$(jq -r --arg k "$slot" '.spaces[$k].color // empty' "$WS_DEFAULTS" 2>/dev/null)
  fi
  printf '%s\n' "${color:-#cdd6f4}"
}

# Lazy-seed default entries up to slot N. Preserves the contiguous-keys
# invariant the rest of the CLI assumes — every missing key in 1..N gets
# a bare `wsK` entry shaped identically to `cmd_add`'s output, so doctor
# stays green and reorder/theme/swap continue to work unchanged.
# No-op if N already exists (or every key 1..N already exists).
_ensure_slot() {
  local target="$1" missing i color
  missing=$(jq -r --argjson n "$target" '
    [range(1; $n + 1)] - (.spaces | keys | map(tonumber))
    | .[]
  ' "$WS_CONFIG")
  [[ -z "$missing" ]] && return 0
  for i in $missing; do
    color=$(_default_color_for_slot "$i")
    _write '
      .spaces[$k] = {
        name: ("ws" + $k),
        color: $c,
        stableLogicalLabel: ("ws" + $k),
        iconSpec: {
          kind: "none",
          fallbackSfSymbol: "stop.fill",
          fallbackText: ("WS" | ascii_upcase),
          userOverridden: false
        }
      }
    ' --arg k "$i" --arg c "$color"
  done
}

# Accept either a numeric slot index OR a slot name. Print the resolved
# slot index to stdout. Exit 2 on no-match / ambiguous.
#
# Numeric input is bounded by `_addressable_max` (WM-derived when
# present), so any aerospace-known workspace is addressable even when it
# carries no JSON identity yet. Name lookup stays JSON-only — names are
# an identity concept, not an existence one; uncustomized slots have no
# name to match.
_resolve_slot() {
  local input="$1"
  local n; n=$(_addressable_max)
  if [[ "$input" =~ ^[1-9][0-9]*$ ]]; then
    if (( input >= 1 && input <= n )); then
      printf '%s\n' "$input"
      return 0
    fi
    if (( n == 0 )); then
      err "slot index out of range: $input (no spaces — Mission Control's + creates one)"
    else
      err "slot index out of range: $input (have $n)"
    fi
    exit 2
  fi
  # Name lookup. Names must match exactly; uniqueness is enforced.
  local matches
  matches=$(jq -r --arg q "$input" '
    .spaces | to_entries | map(select(.value.name == $q) | .key) | .[]
  ' "$WS_CONFIG")
  local n_matches
  n_matches=$(printf '%s' "$matches" | grep -c '^[0-9]' || true)
  if (( n_matches == 1 )); then
    printf '%s\n' "$matches"
    return 0
  elif (( n_matches == 0 )); then
    err "no slot matches '$input' (use a 1..$n index or an exact slot name)"
    exit 2
  else
    err "ambiguous: name '$input' matches multiple slots ($(echo "$matches" | tr '\n' ' '))"
    exit 2
  fi
}

# Legacy name kept for back-compat with existing callsites. Exits on
# failure; otherwise sets nothing (callers that need the resolved index
# should use _resolve_slot directly).
_validate_slot() { _resolve_slot "$1" >/dev/null; }

_validate_color() {
  [[ "$1" =~ ^#[0-9a-fA-F]{6}$ ]] || { err "color must be #RRGGBB (got: $1)"; exit 2; }
}

# Reject a name that starts with a digit. The ws-prompt overlay uses
# "first key is a digit → commit slot N" as its single-digit fast
# path; an all-numeric query (reachable via backspace-erasure) is
# resolved as a literal slot index. That contract only holds if names
# can never begin with a digit, so we enforce it at write time.
_validate_name_format() {
  local name="$1"
  [[ -n "$name" ]] || { err "name cannot be empty"; exit 2; }
  [[ ! "$name" =~ ^[0-9] ]] || {
    err "name cannot start with a digit (reserved for slot indices)"
    exit 2
  }
}

# Reject a name that is already in use on another slot. `add` calls this
# with no exclude. `name` passes the slot being renamed so the rename is
# allowed to keep its own value. Why: _resolve_slot fails closed on
# ambiguous matches (lines 96-104), so silently allowing duplicates here
# breaks slot-lookup-by-name downstream.
_validate_name_unique() {
  local name="$1" exclude="${2:-}"
  local hit
  hit=$(jq -r --arg q "$name" --arg exclude "$exclude" '
    .spaces | to_entries
    | map(select(.value.name == $q and .key != $exclude) | .key)
    | first // empty
  ' "$WS_CONFIG" 2>/dev/null)
  if [[ -n "$hit" ]]; then
    err "name '$name' already exists at slot $hit"
    exit 2
  fi
}

_fire_post() {
  # Backgrounded; failures never abort the caller.
  if [[ -x "$WS_HOOK" ]]; then
    ( "$WS_HOOK" "$@" >/dev/null 2>&1 & ) 2>/dev/null
  fi
}

_fire_cascade() {
  if [[ -x "$WS_HANDLER" ]]; then
    ( "$WS_HANDLER" >/dev/null 2>&1 & ) 2>/dev/null
  fi
}

# Canonical ordering filter run after every mutation. Sorts .spaces
# keys numerically (so 10 comes after 9, not after 1) and writes each
# slot's (name, color) fields in that order. iconSpec (v2) and any
# user-added extras land after, untouched. The legacy `.icon` raw-glyph
# field is actively dropped: with the cascade fully v2-aware
# (on-space-changed.sh and space.sh both prefer iconSpec.codepoint), no
# reader depends on it, so retiring the field keeps diffs clean.
readonly WS_NORMALIZE_JQ='
  .spaces as $s
  | .spaces = (
      reduce ($s | keys | map(tonumber) | sort | map(tostring))[] as $k ({};
        .[$k] = (
          ($s[$k] | {name, color} | with_entries(select(.value != null)))
          + ($s[$k] | del(.name, .color, .icon))
        )
      )
    )
'

# _write <jq-program> [jq-args...]  — atomic mktemp + jq + normalize + validate + mv.
_write() {
  local prog="$1"; shift
  local config_staging; config_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
  if ! jq "$@" "$prog" "$WS_CONFIG" | jq "$WS_NORMALIZE_JQ" > "$config_staging" 2>/dev/null; then
    rm -f "$config_staging"
    err "jq transformation failed"
    exit 1
  fi
  if ! jq -e . "$config_staging" >/dev/null 2>&1; then
    rm -f "$config_staging"
    err "produced invalid JSON (refusing to write)"
    exit 1
  fi
  mv -f "$config_staging" "$WS_CONFIG"
}

# Truecolor swatch helper. Uses the shared ws_hex_to_rgb parser.
_swatch() {
  local r g b
  read -r r g b < <(ws_hex_to_rgb "$1")
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    printf '\033[38;2;%d;%d;%dm▓▓▓\033[0m' "$r" "$g" "$b"
  else
    printf '   '
  fi
}

# Prompt yes/no; returns 0 on yes. Non-tty defaults to no unless -y was passed.
_confirm() {
  local msg="$1" yes="${2:-0}"
  if (( yes )); then return 0; fi
  if [[ ! -t 0 ]]; then return 1; fi
  local ans
  printf '%s [y/N] ' "$msg" >&2
  read -r ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# ── subcommands ─────────────────────────────────────────────────────────

