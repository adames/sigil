#!/usr/bin/env bash
# ws — CLI for per-display workspace identities. Mutates a workspace
# slot's identity (name / icon / color) and dispatches the cascade so
# every consumer (tmux, starship, borders) repaints in
# step. Formerly called `workspace`; the old name is kept as a compat
# symlink so older scripts and muscle-memory continue to work.
#
# Atomic spaces.json writes (mktemp + jq + normalize + mv), then on-space-changed.sh
# fires, then the optional ~/.config/workspace/hooks/post-mutate.sh runs
# as an extension point.
#
# Slot-count agnostic: every subcommand derives the current count from
# the JSON itself, not a hardcoded constant.
#
# Stable contract for callers:
#   exit codes  0 success · 1 runtime error · 2 usage error
#   env overrides  WS_CONFIG, WS_THEMES_DIR, WS_HANDLER, WS_HOOK
#   --json available on  status · get · themes
#
# Naming conventions (read this before adding new names):
#   • file-global names use the WS_* prefix and UPPER_SNAKE_CASE.
#       - Declared as  WS_X="${WS_X:-default}"  → user-overridable env knob.
#       - Declared as  WS_X='literal'  (often `readonly`) → internal
#         constant; callers should treat as immutable.
#   • file-private (within-function) names use lowercase snake_case;
#     transient staging files name themselves by purpose
#     (config_staging, layout_staging, defaults_staging) so a skim
#     reveals what's being written, not just that something is.
#   • functions: cmd_<subcommand>  → public CLI subcommand (1:1 with
#     `ws <subcommand>`). _<name>()  → file-private helper.
#   • boolean knobs phrase the toggle as English. Current set:
#     WS_SKIP_WM_SLOT_CHECK (test harness disables WM-derived bounds so
#     it can exercise JSON-only state). Default = 0.

set -u

# Source workspace configuration (bundle prefix, paths, WM binary).
# This provides: WORKSPACE_BUNDLE_PREFIX, WORKSPACE_WM_BIN, etc.
if [[ -r "$HOME/.config/workspace/lib/config.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/config.sh"
fi

# Source window manager abstraction layer
if [[ -r "$HOME/.config/workspace/lib/window-manager.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/window-manager.sh"
fi

# Resolve WS_CONFIG via the per-host overlay helper (falls back to the
# shared spaces.json when no host-specific file exists). Sourced before
# any other default-resolution so subsequent `${WS_CONFIG:-…}` defaults
# don't clobber the host overlay.
if [[ -r "$HOME/.config/workspace/lib/resolve-config.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/resolve-config.sh"
fi

WS_CONFIG="${WS_CONFIG:-$HOME/.config/workspace/spaces.json}"
WS_THEMES_DIR="${WS_THEMES_DIR:-$HOME/.config/workspace/themes}"
WS_HANDLER="${WS_HANDLER:-$HOME/.config/workspace/on-space-changed.sh}"
WS_HOOK="${WS_HOOK:-$HOME/.config/workspace/hooks/post-mutate.sh}"
WS_DEFAULTS="${WS_DEFAULTS:-$HOME/.config/workspace/spaces.default.json}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# Common helpers if available; tiny stubs otherwise so the CLI stays
# usable on machines without the dotfiles tree.
if [[ -r "$DOTFILES_DIR/lib/common.sh" ]]; then
  # shellcheck source=/dev/null
  . "$DOTFILES_DIR/lib/common.sh"
else
  ok()   { :; }
  step() { :; }
  info() { :; }
  err()  { printf 'ws: %s\n' "$*" >&2; }
  warn() { printf 'ws: %s\n' "$*" >&2; }
  have() { command -v "$1" >/dev/null 2>&1; }
fi

have() { command -v "$1" >/dev/null 2>&1; }   # ensure available regardless

# Shared helpers for codepoint unescape + hex→RGB. Stubs let the CLI keep
# working when the lib/ shipment hasn't landed (very fresh install).
if [[ -r "$HOME/.config/workspace/lib/icon-decode.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/icon-decode.sh"
else
  ws_decode_icon() { :; }
fi
if [[ -r "$HOME/.config/workspace/lib/hex-ansi.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/workspace/lib/hex-ansi.sh"
else
  ws_hex_to_rgb() { printf '0 0 0\n'; }
fi

# ── helpers ─────────────────────────────────────────────────────────────

_require_config() {
  [[ -r "$WS_CONFIG" ]] || { err "spaces.json not found: $WS_CONFIG"; exit 1; }
  jq -e . "$WS_CONFIG" >/dev/null 2>&1 || { err "spaces.json is not valid JSON"; exit 1; }
}

# Count of customized slots (identity overlays). Existence is WM-owned;
# this is just how many workspaces carry a spaces.json identity.
_count() { jq '.spaces | length' "$WS_CONFIG"; }

# Canonical jq sort-key for a composite spaces key — mirrors
# Migration.spacesSortKey (Sources/WorkspaceState/Migration.swift): composite
# keys `<displayUUID>:<workspaceName>` group by displayUUID, then by
# workspaceName lexically (U+001F separator); non-composite keys (invalid
# under v3) sort last. Shared by `_ws_names` and `WS_NORMALIZE_JQ` so the
# on-disk order matches what the Swift renderer emits. `.` is the key string.
readonly WS_KEY_SORT_JQ='
  def _ws_sortkey:
    (index(":")) as $c
    | if $c then [0, (.[:$c]) + "" + (.[$c+1:]), .]
      else [1, ., .] end;
'

# Aerospace workspace names, in aerospace order (existence is WM-owned).
# Falls back to the spaces.json workspaceNames in canonical order when the
# WM is unavailable (Linux, harness, daemon down).
_ws_names() {
  local names=""
  if _wm_available; then
    names=$(wm_query_spaces 2>/dev/null | jq -r '.[].workspace' 2>/dev/null)
  fi
  if [[ -n "$names" ]]; then
    printf '%s\n' "$names"
    return 0
  fi
  jq -r "$WS_KEY_SORT_JQ"'
    .spaces | to_entries | sort_by(.key | _ws_sortkey) | .[].value.workspaceName
  ' "$WS_CONFIG" 2>/dev/null
}

# Composite spaces.json key for a workspaceName: the existing key whose
# .workspaceName matches (any displayUUID prefix), else the `_unassigned`
# wildcard sentinel. The shell can't compute a CG display UUID
# (CGDisplayCreateUUIDFromDisplayID is Swift-only), so new identity
# overlays land under _unassigned; the Swift side rebinds the real UUID
# when it resolves the workspace to a monitor.
_key_for_ws() {
  local w="$1" existing
  existing=$(jq -r --arg w "$w" '
    .spaces | to_entries
    | map(select(.value.workspaceName == $w) | .key) | first // empty
  ' "$WS_CONFIG" 2>/dev/null)
  printf '%s\n' "${existing:-_unassigned:$w}"
}

# Full default v3 slot object for a workspaceName, emitted compact for
# --argjson seeding on first write. Color is a neutral placeholder until
# `ws theme` paints it (colors are theme-driven, never per-slot).
_seed_json() {
  jq -cn --arg w "$1" '{
    name: $w,
    color: "#cdd6f4",
    iconSpec: {
      kind: "none",
      fallbackSfSymbol: "stop.fill",
      fallbackText: ($w[0:2] | ascii_upcase),
      userOverridden: false
    },
    stableLogicalLabel: ("ws" + $w),
    displayUUID: "_unassigned",
    workspaceName: $w
  }'
}

# Resolve a user argument to an aerospace workspaceName. Prints it; exit 2
# on no-match / ambiguous.
#   1. exact match against an aerospace workspace name (existence)
#   2. else a unique match against a slot's identity .name
# Identity names can't start with a digit (see _validate_name_format), so
# they never collide with aerospace's numeric workspace names.
_resolve_ws() {
  local input="$1"

  # 1. aerospace workspace name (existence is WM-owned; falls back to
  #    spaces.json workspaceNames when the WM is down).
  if _ws_names | grep -qxF -- "$input"; then
    printf '%s\n' "$input"
    return 0
  fi

  # 2. identity-name lookup → that slot's workspaceName.
  local matches
  matches=$(jq -r --arg q "$input" '
    .spaces | to_entries
    | map(select(.value.name == $q) | .value.workspaceName) | .[]
  ' "$WS_CONFIG" 2>/dev/null)
  local n_matches; n_matches=$(printf '%s' "$matches" | grep -c . || true)
  if (( n_matches == 1 )); then
    printf '%s\n' "$matches"
    return 0
  elif (( n_matches > 1 )); then
    err "ambiguous: name '$input' matches workspaces ($(printf '%s' "$matches" | tr '\n' ' '))"
    exit 2
  fi

  err "no workspace matches '$input' (use an aerospace workspace name or an exact identity name)"
  exit 2
}

_validate_color() {
  [[ "$1" =~ ^#[0-9a-fA-F]{6}$ ]] || { err "color must be #RRGGBB (got: $1)"; exit 2; }
}

# Reject a name that starts with a digit. The ws-prompt overlay uses
# "first key is a digit → commit slot N" as its single-digit fast
# path; an all-numeric query (reachable via backspace-erasure) is
# resolved as a literal slot index. That contract only holds if names
# can never begin with a digit, so we enforce it at write time.
_validate_name_format() {
  local name="$1"
  [[ -n "$name" ]] || { err "name cannot be empty"; exit 2; }
  [[ ! "$name" =~ ^[0-9] ]] || {
    err "name cannot start with a digit (reserved for slot indices)"
    exit 2
  }
}

# Reject a name already in use on another workspace. `name` passes the
# workspaceName being renamed (as exclude) so a slot can keep its own
# value. Why: _resolve_ws's name lookup fails closed on ambiguous
# matches, so silently allowing duplicates here breaks lookup-by-name.
_validate_name_unique() {
  local name="$1" exclude="${2:-}"
  local hit
  hit=$(jq -r --arg q "$name" --arg exclude "$exclude" '
    .spaces | to_entries
    | map(select(.value.name == $q and .value.workspaceName != $exclude) | .value.workspaceName)
    | first // empty
  ' "$WS_CONFIG" 2>/dev/null)
  if [[ -n "$hit" ]]; then
    err "name '$name' already in use on workspace $hit"
    exit 2
  fi
}

_fire_post() {
  # Backgrounded; failures never abort the caller.
  if [[ -x "$WS_HOOK" ]]; then
    ( "$WS_HOOK" "$@" >/dev/null 2>&1 & ) 2>/dev/null
  fi
}

_fire_cascade() {
  if [[ -x "$WS_HANDLER" ]]; then
    ( "$WS_HANDLER" >/dev/null 2>&1 & ) 2>/dev/null
  fi
}

# Canonical ordering filter run after every mutation. Reorders .spaces by
# the v3 composite-key sort (WS_KEY_SORT_JQ — same order the Swift renderer
# emits, so diffs stay clean) and leaves every slot's fields untouched.
readonly WS_NORMALIZE_JQ="$WS_KEY_SORT_JQ"'
  .spaces |= (
    to_entries
    | sort_by(.key | _ws_sortkey)
    | from_entries
  )
'

# _write <jq-program> [jq-args...]  — atomic mktemp + jq + normalize + validate + mv.
_write() {
  local prog="$1"; shift
  local config_staging; config_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
  if ! jq "$@" "$prog" "$WS_CONFIG" | jq "$WS_NORMALIZE_JQ" > "$config_staging" 2>/dev/null; then
    rm -f "$config_staging"
    err "jq transformation failed"
    exit 1
  fi
  if ! jq -e . "$config_staging" >/dev/null 2>&1; then
    rm -f "$config_staging"
    err "produced invalid JSON (refusing to write)"
    exit 1
  fi
  mv -f "$config_staging" "$WS_CONFIG"
}

# Truecolor swatch helper. Uses the shared ws_hex_to_rgb parser.
_swatch() {
  local r g b
  read -r r g b < <(ws_hex_to_rgb "$1")
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    printf '\033[38;2;%d;%d;%dm▓▓▓\033[0m' "$r" "$g" "$b"
  else
    printf '   '
  fi
}

# Prompt yes/no; returns 0 on yes. Non-tty defaults to no unless -y was passed.
_confirm() {
  local msg="$1" yes="${2:-0}"
  if (( yes )); then return 0; fi
  if [[ ! -t 0 ]]; then return 1; fi
  local ans
  printf '%s [y/N] ' "$msg" >&2
  read -r ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# ── subcommands ─────────────────────────────────────────────────────────

cmd_help() {
  cat <<'EOF_HELP'
ws — overlay an identity (name / icon) onto aerospace workspaces.

AeroSpace owns workspace existence and order (declared in aerospace.toml);
this CLI only attaches optional metadata. Address a workspace by its
aerospace name (e.g. `2`) or by a unique identity name (e.g. `dev`).
Colors are theme-driven — `ws theme NAME [--with-icons]` repaints the
whole palette; there is no per-slot color override. Uncustomized
workspaces render bare (wsN / neutral). (`workspace` remains a compat alias.)

USAGE
  ws <subcommand> [args]
  (anywhere a workspace is expected, pass its aerospace name or a unique identity name)

INSPECTION
  status [--json]            list workspaces with identity + color swatches
  get <WS> [--json]          dump a workspace's identity overlay as JSON
  count [--customized]       workspace count (default: aerospace's; --customized: # with an overlay)
  themes [--json]            list available themes
  doctor                     validate spaces.json (v3 schema)
  verify                     run end-to-end cascade tests

MUTATION  (every mutation fires the cascade + post-mutate hook)
  name <WS> <NEW_NAME>             set a workspace's identity name
  icon <WS> [GLYPH]                set a workspace's icon (no arg → fzf picker)
  icon search <TERM>               non-interactive list of SF Symbols
  theme <NAME> [--with-icons]      apply a palette across all workspaces
  edit                             open spaces.json in $EDITOR
  reset [-y]                       restore spaces.json from spaces.default.json

LAYOUTS  (named snapshots, per-machine)
  layout save <NAME>               snapshot current state
  layout load <NAME> [-y]          restore a saved snapshot
  layout list                      list saved layouts
  layout delete <NAME> [-y]        remove a saved layout

SYSTEM
  migrate [--apply]                validate / re-render spaces.json (delegates to ws-topology)
  host {status|init|reset|list}    per-host overlay (spaces.<hostname>.json)
  refresh [--full]                 force re-run cascade

ENV OVERRIDES
  WS_CONFIG       path to spaces.json     (default: ~/.config/workspace/spaces.json)
  WS_THEMES_DIR   themes directory        (default: ~/.config/workspace/themes)
  WS_HANDLER      cascade entry point     (default: ~/.config/workspace/on-space-changed.sh)
  WS_HOOK         post-mutate hook        (default: ~/.config/workspace/hooks/post-mutate.sh)
  WS_LAYOUTS_DIR  layouts directory       (default: ~/.config/workspace/layouts)

EXIT CODES
  0 success · 1 runtime error · 2 usage error

Hotkey note: aerospace.toml binds Caps+1..0 to the first 10 workspaces
(regenerated by `ws-topology emit-aerospace --write`). Workspaces beyond
ten have no digit chord; reach them via `Caps+f` then type the name.
EOF_HELP
}

cmd_status() {
  _require_config
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  if (( json )); then
    jq '.spaces' "$WS_CONFIG"
    return
  fi
  # Existence is WM-owned: enumerate aerospace's workspaces (falling back
  # to spaces.json workspaceNames when the WM is down) and overlay each
  # one's identity, keyed by workspaceName. Uncustomized workspaces render
  # with bare wsN / neutral defaults rather than being hidden.
  local names; names=$(_ws_names)
  if [[ -z "$names" ]]; then
    printf '(no workspaces \u2014 declare them in ~/.config/aerospace/aerospace.toml)\n'
    return
  fi
  printf '%-4s %-4s %-12s %-9s %s\n' 'WS' 'ICON' 'NAME' 'COLOR' ''
  # Index identity by workspaceName, then join against the WM order.
  # Fields separated by U+001F so empty fields (codepoint-less kind=none
  # slots) align under bash's whitespace IFS.
  local names_json; names_json=$(printf '%s\n' "$names" | jq -R . | jq -s .)
  while IFS=$'\x1f' read -r w name color cp ft; do
    local glyph
    if [[ -n "$cp" ]]; then
      glyph=$(ws_decode_icon "$cp")
    else
      glyph="$ft"
    fi
    printf '%-4s %-4s %-12s %-9s %s\n' "$w" "$glyph" "$name" "$color" "$(_swatch "$color")"
  done < <(jq -r --argjson names "$names_json" '
    (.spaces | to_entries | map({key: .value.workspaceName, value: .value}) | from_entries) as $byname
    | $names[]
    | . as $w
    | ($byname[$w] // {}) as $m
    | [
        $w,
        ($m.name // $w),
        ($m.color // "#cdd6f4"),
        ($m.iconSpec.codepoint // ""),
        ($m.iconSpec.fallbackText // "")
      ]
    | join("\u001f")
  ' "$WS_CONFIG")
}

cmd_get() {
  _require_config
  [[ $# -ge 1 ]] || { err "usage: ws get <WORKSPACE_OR_NAME>"; exit 2; }
  local w; w=$(_resolve_ws "$1") || exit $?
  local key; key=$(_key_for_ws "$w")
  jq --arg k "$key" '.spaces[$k] // {}' "$WS_CONFIG"
}

cmd_count() {
  _require_config
  # Default: aerospace's workspace count (existence is WM-owned).
  # `--customized` returns the count of slots carrying a spaces.json
  # identity overlay.
  if [[ "${1:-}" == "--customized" ]]; then
    _count
  else
    _ws_names | grep -c . || true
  fi
}

cmd_themes() {
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  local names=()
  if [[ -d "$WS_THEMES_DIR" ]]; then
    local f
    for f in "$WS_THEMES_DIR"/*.json; do
      [[ -f "$f" ]] || continue
      names+=("$(basename "$f" .json)")
    done
  fi
  if (( json )); then
    printf '%s\n' "${names[@]:-}" | jq -R . | jq -s .
  else
    printf '%s\n' "${names[@]:-}"
  fi
}

cmd_name() {
  _require_config
  [[ $# -eq 2 ]] || { err "usage: ws name <WORKSPACE_OR_NAME> <NEW_NAME>"; exit 2; }
  local w; w=$(_resolve_ws "$1") || exit $?
  _validate_name_format "$2"
  _validate_name_unique "$2" "$w"
  local key; key=$(_key_for_ws "$w")
  local seed; seed=$(_seed_json "$w")
  _write '.spaces[$k] = ((.spaces[$k] // $seed) + {name: $v})' \
    --arg k "$key" --arg v "$2" --argjson seed "$seed"
  _fire_post name "$w"
  _fire_cascade
}

# `ws color N #hex` was retired — slot colors are theme-driven, not
# user-supplied. Use `ws theme NAME` to change the palette; per-slot
# overrides are no longer part of the CLI surface.

# Curated SF Symbols offered by the icon picker + `ws icon search`. SF
# Symbols are stored by name and render natively in the AppKit/SwiftUI
# overlays on macOS.
readonly WS_ICON_SYMBOLS=(
  "house.fill" "globe" "terminal.fill" "chevron.left.forwardslash.chevron.right"
  "brain.head.profile" "cpu.fill" "arrow.triangle.branch" "envelope.fill"
  "bubble.left.fill" "music.note" "play.rectangle.fill" "doc.text.fill"
  "cloud.fill" "shippingbox.fill" "cylinder.split.1x2.fill" "lock.fill"
  "gearshape.fill" "calendar" "cart.fill" "at" "gamecontroller.fill"
  "photo.fill" "paintbrush.fill" "newspaper.fill" "heart.fill" "map.fill"
  "chart.line.uptrend.xyaxis" "checkmark.seal.fill" "hammer.fill" "magnifyingglass"
  "bell.fill" "bookmark.fill" "folder.fill" "tray.fill" "archivebox.fill"
  "paperplane.fill" "link" "person.fill" "person.2.fill" "moon.fill" "sun.max.fill"
  "star.fill" "flag.fill" "tag.fill" "bolt.fill" "flame.fill" "drop.fill"
  "wifi" "battery.100" "display" "keyboard" "mouse" "printer.fill"
)

# Interactive fzf icon picker. Prints the selected SF Symbol name to
# stdout; returns non-zero (printing nothing) if cancelled or fzf isn't
# available. Used by `ws icon <slot>` when no glyph is passed.
_pick_icon_fzf() {
  local prompt="${1:-icon> }"
  have fzf || return 1
  local picked
  picked=$(printf '%s\n' "${WS_ICON_SYMBOLS[@]}" \
  | fzf --prompt="$prompt" \
        --header="ENTER: apply · ESC: cancel · Type to filter SF Symbols" \
        --reverse --height=40%)
  [[ -n "$picked" ]] || return 1
  printf '%s' "$picked"
}

# Resolve a single icon argument. An SF Symbol identifier is stored by
# name; anything else is treated as a literal glyph and encoded as a
# codepoint escape. Sets:
#   _ICON_SF_NAME   — SF Symbol name, or empty
#   _ICON_ESCAPED   — \uXXXX / \u{X..} escape for a literal glyph, or empty
_resolve_icon_input() {
  local input="$1"
  _ICON_ESCAPED=""
  _ICON_SF_NAME=""
  [[ -z "$input" ]] && return 0

  if [[ "$input" =~ ^[a-z][a-z0-9._]*$ ]]; then
    # SF Symbol identifier - store directly without Nerd Font mapping
    _ICON_SF_NAME="$input"
    return 0
  fi

  # Literal glyph path. Extract the FIRST scalar; encode as \uXXXX or \u{X..}.
  local form="" hex=""
  read -r form hex < <(
    printf '%s' "$input" | python3 -c '
import sys
s = sys.stdin.read()
if s:
    cp = ord(s[0])
    if cp <= 0xFFFF:
        print("B", f"{cp:04x}")
    else:
        print("S", f"{cp:X}")
' 2>/dev/null
  )
  case "$form" in
    B) _ICON_ESCAPED="\\u${hex}" ;;
    S) _ICON_ESCAPED="\\u{${hex}}" ;;
  esac
}

cmd_icon() {
  _require_config

  # `workspace icon search <term>` — non-interactive SF Symbol list dump.
  if [[ "${1:-}" == "search" ]]; then
    shift
    local q="${1:-}"
    printf '%s\n' "${WS_ICON_SYMBOLS[@]}" \
    | { [[ -n "$q" ]] && grep -i "$q" || cat; } \
    | while read -r name; do
        printf '  %s\n' "$name"
      done
    return 0
  fi

  if [[ $# -lt 1 || $# -gt 2 ]]; then
    err "usage: ws icon <SLOT_OR_NAME> [SF_SYMBOL_NAME]"
    err "       ws icon search <term>"
    err "   (omit SF_SYMBOL_NAME for an interactive fzf picker)"
    err "   examples: ws icon 1 house.fill   ws icon web globe"
    exit 2
  fi
  local w; w=$(_resolve_ws "$1") || exit $?
  local arg="${2:-}"

  # Interactive picker when no SF Symbol was passed. Uses fzf to pick
  # from curated SF Symbol list. Selection feeds back into write path.
  if [[ -z "$arg" ]]; then
    arg=$(_pick_icon_fzf "icon for workspace $w> ") || {
      warn "no selection — workspace $w unchanged"; exit 1;
    }
  fi

  _resolve_icon_input "$arg"

  # Decide kind: sfSymbol if we identified an SF name, else "none" (cleared).
  # userOverridden=true on explicit edit.
  local kind="none"
  if [[ -n "$_ICON_SF_NAME" ]]; then
    kind="sfSymbol"
  fi
  # Seed the slot if it has no identity overlay yet, then rebuild iconSpec
  # (preserving fallback fields; synthesizing them from name when absent).
  local key; key=$(_key_for_ws "$w")
  local seed; seed=$(_seed_json "$w")
  _write '
    .spaces[$k] = (
      (.spaces[$k] // $seed) as $s
      | $s | .iconSpec = (
          {
            kind: $kind,
            fallbackSfSymbol: ($s.iconSpec.fallbackSfSymbol // "stop.fill"),
            fallbackText: ($s.iconSpec.fallbackText // (($s.name // "") | .[0:2] | ascii_upcase)),
            userOverridden: true
          }
          + (if $sf != "" then {symbolName: $sf} else {} end)
        )
    )
  ' --arg k "$key" --arg kind "$kind" --arg sf "$_ICON_SF_NAME" --argjson seed "$seed"
  _fire_post icon "$w"
  _fire_cascade
}

cmd_migrate() {
  # Thin delegate to ws-topology — validates v3 and re-renders canonically.
  # Dry-run by default; --apply rewrites in place.
  if ! command -v ws-topology >/dev/null 2>&1; then
    err "ws-topology not on PATH (build + symlink from ~/.config/workspace/topology)"
    exit 1
  fi
  ws-topology migrate "$@"
}

cmd_refresh() {
  # Force-re-run the cascade end-to-end. Useful after editing
  # spaces.json by hand, after swapping the active host overlay, or
  # any time the bar / borders / tmux env look stale.
  #
  # --full also asks ws-topologyd to republish topology.json + layout.env
  # (otherwise those refresh only on display reconfiguration events).
  local full=0
  for arg in "$@"; do
    case "$arg" in
      --full) full=1 ;;
      -h|--help)
        cat <<'EOF_REFRESH_HELP' >&2
usage: ws refresh [--full]

Re-run the cascade:
  1. on-space-changed.sh   rewrite current.env + repaint borders

With --full, also kickstarts ws-topologyd so topology.json / layout.env
are re-emitted (normally only refreshed on display add/remove/change).
EOF_REFRESH_HELP
        return 0
        ;;
    esac
  done

  if [[ -x "$WS_HANDLER" ]]; then
    "$WS_HANDLER" || warn "cascade handler exited non-zero"
  else
    warn "cascade handler not executable: $WS_HANDLER"
  fi

  if (( full )); then
    local daemon_label="${WORKSPACE_BUNDLE_PREFIX:-com.user.workspace}.topologyd"
    if launchctl print "gui/$(id -u)/$daemon_label" >/dev/null 2>&1; then
      launchctl kickstart -k "gui/$(id -u)/$daemon_label" 2>/dev/null || true
      printf 'ws: refreshed (--full: daemon %s kicked)\n' "$daemon_label" >&2
      return 0
    else
      warn "ws-topologyd not loaded; --full skipped"
    fi
  fi
  printf 'ws: refreshed\n' >&2
}

# ── host overlay management ─────────────────────────────────────────────
# Per-host workspace identity: ~/.config/workspace/spaces.<hostname>.json
# overrides ~/.config/workspace/spaces.json on this machine.
# Useful for divergent identities between machines.

_host_short() { hostname -s 2>/dev/null || echo unknown; }
_host_file()  { printf '%s/.config/workspace/spaces.%s.json' "$HOME" "$1"; }

cmd_host() {
  local sub="${1:-status}"; shift 2>/dev/null || true
  case "$sub" in
    status|"")  _host_status ;;
    init)       _host_init "$@" ;;
    reset)      _host_reset "$@" ;;
    list)       _host_list ;;
    *)
      err "usage: ws host {status|init [HOST]|reset [HOST]|list}"
      exit 2 ;;
  esac
}

_host_status() {
  local h; h=$(_host_short)
  local hf; hf=$(_host_file "$h")
  printf 'hostname     %s\n' "$h"
  printf 'effective    %s\n' "$WS_CONFIG"
  if [[ -r "$hf" ]]; then
    printf 'overlay      yes (%s)\n' "$hf"
  else
    printf 'overlay      no (would be %s)\n' "$hf"
  fi
}

_host_init() {
  local target="${1:-$(_host_short)}"
  local hf; hf=$(_host_file "$target")
  if [[ -e "$hf" ]]; then
    err "$hf already exists; refusing to overwrite (use 'ws host reset $target' first)"
    exit 1
  fi
  local shared="$HOME/.config/workspace/spaces.json"
  if [[ ! -r "$shared" ]]; then
    err "shared $shared not found; nothing to fork from"
    exit 1
  fi
  cp "$shared" "$hf"
  printf 'forked %s → %s\n' "$shared" "$hf" >&2
  printf '%s\n' "$hf"
  _fire_cascade
}

_host_reset() {
  local target="${1:-$(_host_short)}"
  local hf; hf=$(_host_file "$target")
  if [[ ! -e "$hf" ]]; then
    printf 'no overlay at %s; nothing to remove\n' "$hf" >&2
    return 0
  fi
  rm -f "$hf"
  printf 'removed %s (now falling back to shared spaces.json)\n' "$hf" >&2
  _fire_cascade
}

_host_list() {
  local dir="$HOME/.config/workspace"
  local active="$WS_CONFIG"
  find "$dir" -maxdepth 1 -name 'spaces*.json' -type f 2>/dev/null \
    | sort \
    | while read -r f; do
        local marker=" "
        [[ "$f" == "$active" ]] && marker="*"
        printf '%s %s\n' "$marker" "$f"
      done
}

cmd_layout() {
  _require_config
  local layouts_dir="${WS_LAYOUTS_DIR:-$HOME/.config/workspace/layouts}"
  mkdir -p "$layouts_dir"
  local sub="${1:-}"; shift || true
  case "$sub" in
    save)
      [[ $# -eq 1 ]] || { err "usage: ws layout save <NAME>"; exit 2; }
      [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]] || { err "layout name must be [A-Za-z0-9._-]+"; exit 2; }
      local dest="$layouts_dir/$1.json"
      local layout_staging; layout_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
      cp "$WS_CONFIG" "$layout_staging" && mv -f "$layout_staging" "$dest"
      ok "saved layout ${dest/#$HOME/~}"
      ;;
    load)
      local name="" yes=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -y|--yes) yes=1 ;;
          *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
        esac
        shift
      done
      [[ -n "$name" ]] || { err "usage: ws layout load <NAME> [-y]"; exit 2; }
      local src="$layouts_dir/$name.json"
      [[ -r "$src" ]] || { err "layout not found: $src"; exit 1; }
      jq -e . "$src" >/dev/null 2>&1 || { err "layout is malformed JSON: $src"; exit 1; }

      # A layout is just a snapshot of the identity overlay. Existence is
      # WM-owned (aerospace.toml), and v3 overlays are sparse — a workspace
      # with no identity is fine — so there's no count to reconcile here;
      # load replaces the overlay and the cascade repaints. Orphaned
      # entries (no matching aerospace workspace) surface in `ws doctor`.
      _confirm "replace spaces.json identity with layout '$name'?" "$yes" \
        || { warn "aborted"; exit 1; }

      local layout_staging; layout_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
      cp "$src" "$layout_staging" && mv -f "$layout_staging" "$WS_CONFIG"
      _fire_post layout "$name"
      _fire_cascade
      ;;
    list)
      local f
      for f in "$layouts_dir"/*.json; do
        [[ -f "$f" ]] && basename "$f" .json
      done
      ;;
    delete|rm)
      local name="" yes=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -y|--yes) yes=1 ;;
          *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
        esac
        shift
      done
      [[ -n "$name" ]] || { err "usage: ws layout delete <NAME> [-y]"; exit 2; }
      local target="$layouts_dir/$name.json"
      [[ -e "$target" ]] || { err "layout not found: $target"; exit 1; }
      _confirm "delete layout '$name'?" "$yes" || { warn "aborted"; exit 1; }
      rm -f "$target"
      ok "deleted ${target/#$HOME/~}"
      ;;
    ""|-h|--help|help)
      cat <<'EOF_LAYOUT'
ws layout — save / load / list named snapshots of spaces.json

  ws layout save <NAME>          snapshot current state
  ws layout load <NAME> [-y]     restore a saved snapshot
  ws layout list                 list saved layouts
  ws layout delete <NAME> [-y]   remove a saved layout

Layouts are stored in ~/.config/workspace/layouts/<NAME>.json (or
$WS_LAYOUTS_DIR if set). They are per-machine and not committed.
EOF_LAYOUT
      ;;
    *)
      err "unknown layout subcommand: $sub"; exit 2 ;;
  esac
}

cmd_theme() {
  _require_config
  local name="" with_icons=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --with-icons) with_icons=1 ;;
      -*) err "unknown flag: $1"; exit 2 ;;
      *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
    esac
    shift
  done
  [[ -n "$name" ]] || { err "usage: ws theme <NAME> [--with-icons]"; exit 2; }
  local theme_file="$WS_THEMES_DIR/$name.json"
  [[ -r "$theme_file" ]] || { err "theme not found: $theme_file"; exit 1; }
  jq -e . "$theme_file" >/dev/null 2>&1 || { err "theme is malformed JSON: $theme_file"; exit 1; }

  local apply_icons="false"
  (( with_icons )) && apply_icons="true"

  # Pre-resolve theme icons (when --with-icons) into a parallel array of
  # ASCII-escaped codepoints, so jq can patch iconSpec.codepoint per slot
  # without forking _resolve_icon_input mid-reduce. The theme file stores
  # icons as raw glyph strings; we round-trip through _resolve_icon_input
  # to get the same `\uXXXX`/`\u{XXXXX}` form spaces.json uses.
  local theme_icons_json="[]"
  if (( with_icons )); then
    local raw_icons=()
    mapfile -t raw_icons < <(jq -r '.icons // [] | .[]' "$theme_file")
    local escaped=()
    local raw
    for raw in "${raw_icons[@]}"; do
      if [[ -z "$raw" ]]; then
        escaped+=("")
      else
        _resolve_icon_input "$raw"
        escaped+=("$_ICON_ESCAPED")
      fi
    done
    theme_icons_json=$(printf '%s\n' "${escaped[@]:-}" | jq -R . | jq -s .)
  fi

  # Palette colors (and --with-icons glyphs) are positional arrays; apply
  # the i-th entry to the i-th slot in canonical key order — same order the
  # pill strip and Swift renderer use. Existence is WM-owned, so this only
  # paints slots that already carry an identity overlay.
  _write "$WS_KEY_SORT_JQ"'
    . as $orig
    | ($theme[0].colors // []) as $tc
    | ($icons | length) as $ni
    | ($orig.spaces | to_entries | sort_by(.key | _ws_sortkey) | map(.key)) as $keys
    | .spaces = (
        reduce range(0; ($keys | length)) as $i ($orig.spaces;
          ($keys[$i]) as $k
          | .[$k] = (
              (.[$k] // {}) as $s
              | $s
              + (if ($tc | length) > $i then {color: $tc[$i]} else {} end)
              + (
                  if ($apply_icons == "true") and $ni > $i and ($icons[$i] // "") != "" then
                    { iconSpec: (
                        {
                          kind: "nerdFont",
                          fallbackSfSymbol: ($s.iconSpec.fallbackSfSymbol // "stop.fill"),
                          fallbackText: ($s.iconSpec.fallbackText // (($s.name // "") | .[0:2] | ascii_upcase)),
                          userOverridden: false,
                          codepoint: $icons[$i],
                          fontFamily: "JetBrainsMono Nerd Font"
                        }
                    )}
                  else {} end
                )
            )
        )
      )
    | .palette = $name
  ' --slurpfile theme "$theme_file" \
    --arg apply_icons "$apply_icons" --arg name "$name" \
    --argjson icons "$theme_icons_json"
  _fire_post theme
  _fire_cascade
}

cmd_edit() {
  _require_config
  local editor="${EDITOR:-vi}"
  "$editor" "$WS_CONFIG"
  if ! jq -e . "$WS_CONFIG" >/dev/null 2>&1; then
    err "spaces.json is now malformed; refusing to fire cascade (fix the file or run 'ws reset')"
    exit 1
  fi
  _fire_post edit
  _fire_cascade
}

cmd_reset() {
  local yes=0
  [[ "${1:-}" == "-y" || "${1:-}" == "--yes" ]] && yes=1
  [[ -r "$WS_DEFAULTS" ]] || { err "defaults file not found: $WS_DEFAULTS"; exit 1; }
  _confirm "reset spaces.json to defaults from $WS_DEFAULTS?" "$yes" \
    || { warn "aborted"; exit 1; }
  local defaults_staging; defaults_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
  cp -f "$WS_DEFAULTS" "$defaults_staging"
  jq -e . "$defaults_staging" >/dev/null 2>&1 || { rm -f "$defaults_staging"; err "defaults file is malformed"; exit 1; }
  mv -f "$defaults_staging" "$WS_CONFIG"
  _fire_post reset
  _fire_cascade
}

cmd_doctor() {
  if [[ ! -r "$WS_CONFIG" ]]; then
    err "spaces.json not found: $WS_CONFIG"
    return 1
  fi
  if ! jq -e . "$WS_CONFIG" >/dev/null 2>&1; then
    err "spaces.json is not valid JSON"
    return 1
  fi
  local bad=0
  # v3 is the only accepted schema (Migration.currentVersion). Non-v3
  # input means the Swift tools haven't migrated this file — bail early,
  # the composite-key invariants below don't apply.
  local version; version=$(jq -r '.version // 1' "$WS_CONFIG" 2>/dev/null)
  if [[ "$version" != "3" ]]; then
    err "unsupported spaces.json version: $version (only v3 is accepted — rebuild/seed via the Swift tools or \`ws migrate\`)"
    return 1
  fi
  if [[ "$(jq -r '.spaces | type' "$WS_CONFIG" 2>/dev/null)" != "object" ]]; then
    err "spaces is missing or not an object"
    return 1
  fi
  # Per-slot v3 invariants (keyed by the composite <displayUUID>:<workspaceName>):
  #   - key matches <displayUUID>:<workspaceName> AND agrees with the
  #     embedded displayUUID/workspaceName fields (the core v3 identity)
  #   - displayUUID + workspaceName required, non-empty
  #   - name (string) + color (#RRGGBB) + stableLogicalLabel (string)
  #   - iconSpec is an object; kind ∈ {none,sfSymbol,nerdFont};
  #     sfSymbol⇒symbolName, nerdFont⇒codepoint; userOverridden boolean
  local report
  report=$(jq -r '
    .spaces as $s
    | [ $s | to_entries[]
        | select((.key | test("^[^:]+:.+$")) | not)
        | "\(.key): key is not <displayUUID>:<workspaceName>"
      ] + [
        $s | to_entries[]
        | select(((.value.displayUUID // "") == "") or ((.value.workspaceName // "") == ""))
        | "\(.key): displayUUID and workspaceName are required (non-empty)"
      ] + [
        $s | to_entries[]
        | select(((.value.displayUUID // "") != "") and ((.value.workspaceName // "") != ""))
        | select(.key != (.value.displayUUID + ":" + .value.workspaceName))
        | "\(.key): key disagrees with fields (\(.value.displayUUID):\(.value.workspaceName))"
      ] + [
        $s | to_entries[]
        | select(((.value.name | type) != "string") or ((.value.color | type) != "string"))
        | "\(.key): missing/wrong type for name|color"
      ] + [
        $s | to_entries[]
        | select((.value.color // "") | test("^#[0-9a-fA-F]{6}$") | not)
        | "\(.key): color \"\(.value.color)\" is not #RRGGBB"
      ] + [
        $s | to_entries[]
        | select((.value.stableLogicalLabel | type) != "string")
        | "\(.key): stableLogicalLabel must be a string"
      ] + [
        $s | to_entries[]
        | select(.value.iconSpec == null or (.value.iconSpec | type) != "object")
        | "\(.key): iconSpec must be an object"
      ] + [
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select((.value.iconSpec.kind // "") as $k | $k != "sfSymbol" and $k != "nerdFont" and $k != "none")
        | "\(.key): iconSpec.kind \"\(.value.iconSpec.kind)\" must be sfSymbol|nerdFont|none"
      ] + [
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select(.value.iconSpec.kind == "nerdFont")
        | select((.value.iconSpec.codepoint // "") == "" or (.value.iconSpec.codepoint | type) != "string")
        | "\(.key): kind=nerdFont but codepoint missing"
      ] + [
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select(.value.iconSpec.kind == "sfSymbol")
        | select((.value.iconSpec.symbolName // "") == "" or (.value.iconSpec.symbolName | type) != "string")
        | "\(.key): kind=sfSymbol but symbolName missing"
      ] + [
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select(.value.iconSpec.userOverridden != null and (.value.iconSpec.userOverridden | type) != "boolean")
        | "\(.key): iconSpec.userOverridden must be boolean"
      ]
    | .[]
  ' "$WS_CONFIG" 2>/dev/null) || bad=1
  if [[ -n "$report" ]]; then
    while IFS= read -r line; do
      err "$line"
    done <<<"$report"
    bad=1
  fi
  # Duplicate identity names break name→slot lookup; duplicate
  # workspaceNames break the (displayUUID, workspaceName) identity. Both
  # are hard errors.
  local dups
  dups=$(jq -r '[.spaces[].name] | group_by(.) | map(select(length > 1) | .[0]) | .[]' "$WS_CONFIG" 2>/dev/null)
  if [[ -n "$dups" ]]; then
    while IFS= read -r name; do err "duplicate name: $name"; done <<<"$dups"
    bad=1
  fi
  local wdups
  wdups=$(jq -r '[.spaces[].workspaceName] | group_by(.) | map(select(length > 1) | .[0]) | .[]' "$WS_CONFIG" 2>/dev/null)
  if [[ -n "$wdups" ]]; then
    while IFS= read -r w; do err "duplicate workspaceName: $w (one workspace must map to one slot)"; done <<<"$wdups"
    bad=1
  fi
  # Orphan check: a spaces.json overlay whose workspaceName isn't a
  # current aerospace workspace won't render (existence is config-time in
  # aerospace.toml). WS_SKIP_WM_SLOT_CHECK=1 disables it (verify harness).
  if [[ "${WS_SKIP_WM_SLOT_CHECK:-0}" != "1" ]] && _wm_available; then
    local wm_json orphans
    wm_json=$(_ws_names | jq -R . | jq -s .)
    orphans=$(jq -r --argjson wm "$wm_json" '[.spaces[].workspaceName] - $wm | .[]' "$WS_CONFIG" 2>/dev/null)
    if [[ -n "$orphans" ]]; then
      while IFS= read -r o; do
        warn "orphan identity: workspace '$o' has a spaces.json overlay but isn't in aerospace.toml (won't render). Fix: declare it + reload-config, or drop the overlay."
      done <<<"$orphans"
      bad=1
    fi
  fi
  if (( bad )); then
    return 1
  fi
  ok "spaces.json schema OK ($( _count ) identity slots, v3)"
}

cmd_verify() {
  local harness="$HOME/.config/workspace/cli/test-cascade.sh"
  if [[ ! -x "$harness" ]]; then
    harness="$DOTFILES_DIR/configs/workspace/cli/test-cascade.sh"
  fi
  if [[ ! -x "$harness" ]]; then
    err "test-cascade.sh not found (re-run bootstrap?)"
    exit 1
  fi
  exec "$harness" "$@"
}

# ── dispatch ────────────────────────────────────────────────────────────

case "${1:-}" in
  ""|-h|--help|help) cmd_help ;;
  status)            shift; cmd_status   "$@" ;;
  get)               shift; cmd_get      "$@" ;;
  count)             shift; cmd_count    "$@" ;;
  themes)            shift; cmd_themes   "$@" ;;
  name)              shift; cmd_name     "$@" ;;
  icon)              shift; cmd_icon     "$@" ;;
  theme)             shift; cmd_theme    "$@" ;;
  edit)              shift; cmd_edit     "$@" ;;
  reset)             shift; cmd_reset    "$@" ;;
  doctor)            shift; cmd_doctor   "$@" ;;
  verify)            shift; cmd_verify   "$@" ;;
  layout)            shift; cmd_layout   "$@" ;;
  migrate)           shift; cmd_migrate  "$@" ;;
  host)              shift; cmd_host     "$@" ;;
  refresh)           shift; cmd_refresh  "$@" ;;
  *) err "unknown subcommand: $1 (try 'ws --help')"; exit 2 ;;
esac
