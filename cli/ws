}

cmd_status() {
  _require_config
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  if (( json )); then
    jq '.spaces' "$WS_CONFIG"
    return
  fi
  # Row count is addressable_max (aerospace reality when up, JSON keys
  # otherwise) so the table mirrors the pill strip - uncustomized
  # slots render with bare wsN / neutral defaults rather than being
  # hidden. Mirrors paint-all.sh's aerospace-owns-existence join.
  local n; n=$(_addressable_max)
  if (( n == 0 )); then
    printf '(no workspaces — declare them in ~/.config/aerospace/aerospace.toml)\n'
    return
  fi
  printf '%-3s %-4s %-12s %-9s %s\n' '#' 'ICON' 'NAME' 'COLOR' ''
  # Single jq pass; fields separated by U+001F so empty fields
  # (e.g. codepoint-less kind=none slots) align correctly under
  # bash's whitespace IFS.
  while IFS=$'\x1f' read -r i name color cp ft; do
    local glyph
    if [[ -n "$cp" ]]; then
      glyph=$(ws_decode_icon "$cp")
    else
      glyph="$ft"
    fi
    printf '%-3s %-4s %-12s %-9s %s\n' "$i" "$glyph" "$name" "$color" "$(_swatch "$color")"
  done < <(jq -r --argjson n "$n" '
    . as $root
    | [range(1; $n + 1) | tostring][]
    | . as $k
    | ($root.spaces[$k] // {}) as $meta
    | [
        $k,
        ($meta.name // ("ws" + $k)),
        ($meta.color // "#cdd6f4"),
        ($meta.iconSpec.codepoint // ""),
        ($meta.iconSpec.fallbackText // "")
      ]
    | join("")
  ' "$WS_CONFIG")
}

cmd_get() {
  _require_config
  [[ $# -ge 1 ]] || { err "usage: ws get <SLOT_OR_NAME> [--json]"; exit 2; }
  local slot; slot=$(_resolve_slot "$1") || exit $?
  jq --arg k "$slot" '.spaces[$k]' "$WS_CONFIG"
}

cmd_count() {
  _require_config
  # Default: addressable count (matches what the user sees in the pill
  # strip — aerospace's reality). `--customized` returns just the JSON-key
  # count for scripts that care about identity coverage.
  if [[ "${1:-}" == "--customized" ]]; then
    _count
  else
    _addressable_max
  fi
}

cmd_themes() {
  local json=0
  [[ "${1:-}" == "--json" ]] && json=1
  local names=()
  if [[ -d "$WS_THEMES_DIR" ]]; then
    local f
    for f in "$WS_THEMES_DIR"/*.json; do
      [[ -f "$f" ]] || continue
      names+=("$(basename "$f" .json)")
    done
  fi
  if (( json )); then
    printf '%s\n' "${names[@]:-}" | jq -R . | jq -s .
  else
    printf '%s\n' "${names[@]:-}"
  fi
}

cmd_name() {
  _require_config
  [[ $# -eq 2 ]] || { err "usage: ws name <SLOT_OR_NAME> <NEW_NAME>"; exit 2; }
  local slot; slot=$(_resolve_slot "$1") || exit $?
  _validate_name_format "$2"
  _validate_name_unique "$2" "$slot"
  _ensure_slot "$slot"
  _write '.spaces[$k] = ((.spaces[$k] // {}) + {name: $v})' --arg k "$slot" --arg v "$2"
  _fire_post name "$slot"
  _fire_cascade
}

# `ws color N #hex` was retired — slot colors are theme-driven, not
# user-supplied. Use `ws theme NAME` to change the palette; per-slot
# overrides are no longer part of the CLI surface.

# Icon handling: SF Symbols are stored directly by name.
# Nerd Font support is available for cross-platform use but SF Symbols
# are the default on macOS for native AppKit/SwiftUI rendering.
# Derive icon from a single argument. Sets:
#   _ICON_SF_NAME   — SF Symbol name (e.g. "play.fill") or empty
# Interactive fzf icon picker. Prints the selected SF Symbol name to
# stdout. Returns non-zero (and prints nothing) if cancelled or fzf
# isn't available. Reused by `ws icon <slot>` and `ws add`.
_pick_icon_fzf() {
  local prompt="${1:-icon> }"
  have fzf || return 1
  local picked
  # Curated SF Symbols for common workspace types
  picked=$(printf '%s\n' \
    "house.fill" "globe" "terminal.fill" "chevron.left.forwardslash.chevron.right" \
    "brain.head.profile" "cpu.fill" "arrow.triangle.branch" "envelope.fill" \
    "bubble.left.fill" "music.note" "play.rectangle.fill" "doc.text.fill" \
    "cloud.fill" "shippingbox.fill" "cylinder.split.1x2.fill" "lock.fill" \
    "gearshape.fill" "calendar" "cart.fill" "at" "gamecontroller.fill" \
    "photo.fill" "paintbrush.fill" "newspaper.fill" "heart.fill" "map.fill" \
    "chart.line.uptrend.xyaxis" "checkmark.seal.fill" "hammer.fill" "magnifyingglass" \
    "bell.fill" "bookmark.fill" "folder.fill" "tray.fill" "archivebox.fill" \
    "paperplane.fill" "link" "person.fill" "person.2.fill" "moon.fill" "sun.max.fill" \
    "star.fill" "flag.fill" "tag.fill" "bolt.fill" "flame.fill" "drop.fill" \
    "wifi" "battery.100" "display" "keyboard" "mouse" "printer.fill" \
  | fzf --prompt="$prompt" \
        --header="ENTER: apply · ESC: cancel · Type to filter SF Symbols" \
        --reverse --height=40%)
  [[ -n "$picked" ]] || return 1
  printf '%s' "$picked"
}

_resolve_icon_input() {
  local input="$1"
  _ICON_ESCAPED=""
  _ICON_SF_NAME=""
  [[ -z "$input" ]] && return 0

  if [[ "$input" =~ ^[a-z][a-z0-9._]*$ ]]; then
    # SF Symbol identifier - store directly without Nerd Font mapping
    _ICON_SF_NAME="$input"
    return 0
  fi

  # Literal glyph path. Extract the FIRST scalar; encode as \uXXXX or \u{X..}.
  local form="" hex=""
  read -r form hex < <(
    printf '%s' "$input" | python3 -c '
import sys
s = sys.stdin.read()
if s:
    cp = ord(s[0])
    if cp <= 0xFFFF:
        print("B", f"{cp:04x}")
    else:
        print("S", f"{cp:X}")
' 2>/dev/null
  )
  case "$form" in
    B) _ICON_ESCAPED="\\u${hex}" ;;
    S) _ICON_ESCAPED="\\u{${hex}}" ;;
  esac
}

cmd_icon() {
  _require_config

  # `workspace icon search <term>` — non-interactive SF Symbol list dump.
  if [[ "${1:-}" == "search" ]]; then
    shift
    local q="${1:-}"
    # Curated SF Symbols for workspace icons
    printf '%s\n' \
      "house.fill" "globe" "terminal.fill" "chevron.left.forwardslash.chevron.right" \
      "brain.head.profile" "cpu.fill" "arrow.triangle.branch" "envelope.fill" \
      "bubble.left.fill" "music.note" "play.rectangle.fill" "doc.text.fill" \
      "cloud.fill" "shippingbox.fill" "cylinder.split.1x2.fill" "lock.fill" \
      "gearshape.fill" "calendar" "cart.fill" "at" "gamecontroller.fill" \
      "photo.fill" "paintbrush.fill" "newspaper.fill" "heart.fill" "map.fill" \
      "chart.line.uptrend.xyaxis" "checkmark.seal.fill" "hammer.fill" "magnifyingglass" \
      "bell.fill" "bookmark.fill" "folder.fill" "tray.fill" "archivebox.fill" \
      "paperplane.fill" "link" "person.fill" "person.2.fill" "moon.fill" "sun.max.fill" \
      "star.fill" "flag.fill" "tag.fill" "bolt.fill" "flame.fill" "drop.fill" \
      "wifi" "battery.100" "display" "keyboard" "mouse" "printer.fill" \
    | { [[ -n "$q" ]] && grep -i "$q" || cat; } \
    | while read -r name; do
        printf '  %s\n' "$name"
      done
    return 0
  fi

  if [[ $# -lt 1 || $# -gt 2 ]]; then
    err "usage: ws icon <SLOT_OR_NAME> [SF_SYMBOL_NAME]"
    err "       ws icon search <term>"
    err "   (omit SF_SYMBOL_NAME for an interactive fzf picker)"
    err "   examples: ws icon 1 house.fill   ws icon web globe"
    exit 2
  fi
  local slot; slot=$(_resolve_slot "$1") || exit $?
  local arg="${2:-}"

  # Interactive picker when no SF Symbol was passed. Uses fzf to pick
  # from curated SF Symbol list. Selection feeds back into write path.
  if [[ -z "$arg" ]]; then
    arg=$(_pick_icon_fzf "icon for slot $slot> ") || {
      warn "no selection — slot $slot unchanged"; exit 1;
    }
  fi

  _ensure_slot "$slot"
  _resolve_icon_input "$arg"

  # Decide kind: sfSymbol if we identified an SF name, else "none" (cleared).
  # userOverridden=true on explicit edit. Nerd Font kind available for
  # cross-platform use via direct codepoint input.
  local kind="none"
  if [[ -n "$_ICON_SF_NAME" ]]; then
    kind="sfSymbol"
  fi
  # Build iconSpec fresh with SF Symbol. Preserves fallback fields.
  # On slots that never had iconSpec, fallback fields synthesized from name.
  _write '
    .spaces[$k] |= (
      . as $s
      | .iconSpec = (
          {
            kind: $kind,
            fallbackSfSymbol: (($s.iconSpec.fallbackSfSymbol) // "stop.fill"),
            fallbackText: (($s.iconSpec.fallbackText) // (($s.name // "") | .[0:2] | ascii_upcase)),
            userOverridden: true
          }
          + (if $sf != "" then {symbolName: $sf} else {} end)
        )
    )
  ' --arg k "$slot" --arg kind "$kind" --arg cp "$_ICON_ESCAPED" --arg sf "$_ICON_SF_NAME"
  _fire_post icon "$slot"
  _fire_cascade
}

cmd_migrate() {
  # Thin delegate to ws-topology. Dry-run by default; --apply writes
  # v2 in place. Idempotent on already-v2 files. Useful for importing
  # a legacy v1 spaces.json from an old backup or fresh-install seed.
  if ! command -v ws-topology >/dev/null 2>&1; then
    err "ws-topology not on PATH (build + symlink from ~/.config/workspace/topology)"
    exit 1
  fi
  ws-topology migrate "$@"
}

cmd_refresh() {
  # Force-re-run the cascade end-to-end. Useful after editing
  # spaces.json by hand, after swapping the active host overlay, or
  # any time the bar / borders / tmux env look stale.
  #
  # --full also asks ws-topologyd to republish topology.json + layout.env
  # (otherwise those refresh only on display reconfiguration events).
  local full=0
  for arg in "$@"; do
    case "$arg" in
      --full) full=1 ;;
      -h|--help)
        cat <<'EOF_REFRESH_HELP' >&2
usage: ws refresh [--full]

Re-run the cascade:
  1. on-space-changed.sh   rewrite current.env + repaint borders + trigger sketchybar
  2. per-display-pills.sh  re-apply pill display assignment + density + anchor

With --full, also kickstarts ws-topologyd so topology.json / layout.env
are re-emitted (normally only refreshed on display add/remove/change).
EOF_REFRESH_HELP
        return 0
        ;;
    esac
  done

  if [[ -x "$WS_HANDLER" ]]; then
    "$WS_HANDLER" || warn "cascade handler exited non-zero"
  else
    warn "cascade handler not executable: $WS_HANDLER"
  fi

  local pills="$HOME/.config/sketchybar/plugins/per-display-pills.sh"
  if [[ -x "$pills" ]]; then
    "$pills" >/dev/null 2>&1 || warn "per-display-pills.sh exited non-zero"
  fi

  if (( full )); then
    local daemon_label="${WORKSPACE_BUNDLE_PREFIX:-com.user.workspace}.topologyd"
    if launchctl print "gui/$(id -u)/$daemon_label" >/dev/null 2>&1; then
      launchctl kickstart -k "gui/$(id -u)/$daemon_label" 2>/dev/null || true
      printf 'ws: refreshed (--full: daemon %s kicked)\n' "$daemon_label" >&2
      return 0
    else
      warn "ws-topologyd not loaded; --full skipped"
    fi
  fi
  printf 'ws: refreshed\n' >&2
}

# ── host overlay management ─────────────────────────────────────────────
# Per-host workspace identity: ~/.config/workspace/spaces.<hostname>.json
# overrides ~/.config/workspace/spaces.json on this machine. Both files
# are valid v2 configs; the overlay simply takes precedence when present.
# Useful for divergent slot identities between machines (the M3 Max and
# the M1 13" may want different slot 8 names, for instance).

_host_short() { hostname -s 2>/dev/null || echo unknown; }
_host_file()  { printf '%s/.config/workspace/spaces.%s.json' "$HOME" "$1"; }

cmd_host() {
  local sub="${1:-status}"; shift 2>/dev/null || true
  case "$sub" in
    status|"")  _host_status ;;
    init)       _host_init "$@" ;;
    reset)      _host_reset "$@" ;;
    list)       _host_list ;;
    *)
      err "usage: ws host {status|init [HOST]|reset [HOST]|list}"
      exit 2 ;;
  esac
}

_host_status() {
  local h; h=$(_host_short)
  local hf; hf=$(_host_file "$h")
  printf 'hostname     %s\n' "$h"
  printf 'effective    %s\n' "$WS_CONFIG"
  if [[ -r "$hf" ]]; then
    printf 'overlay      yes (%s)\n' "$hf"
  else
    printf 'overlay      no (would be %s)\n' "$hf"
  fi
}

_host_init() {
  local target="${1:-$(_host_short)}"
  local hf; hf=$(_host_file "$target")
  if [[ -e "$hf" ]]; then
    err "$hf already exists; refusing to overwrite (use 'ws host reset $target' first)"
    exit 1
  fi
  local shared="$HOME/.config/workspace/spaces.json"
  if [[ ! -r "$shared" ]]; then
    err "shared $shared not found; nothing to fork from"
    exit 1
  fi
  cp "$shared" "$hf"
  printf 'forked %s → %s\n' "$shared" "$hf" >&2
  printf '%s\n' "$hf"
  _fire_cascade
}

_host_reset() {
  local target="${1:-$(_host_short)}"
  local hf; hf=$(_host_file "$target")
  if [[ ! -e "$hf" ]]; then
    printf 'no overlay at %s; nothing to remove\n' "$hf" >&2
    return 0
  fi
  rm -f "$hf"
  printf 'removed %s (now falling back to shared spaces.json)\n' "$hf" >&2
  _fire_cascade
}

_host_list() {
  local dir="$HOME/.config/workspace"
  local active="$WS_CONFIG"
  find "$dir" -maxdepth 1 -name 'spaces*.json' -type f 2>/dev/null \
    | sort \
    | while read -r f; do
        local marker=" "
        [[ "$f" == "$active" ]] && marker="*"
        printf '%s %s\n' "$marker" "$f"
      done
}

# Default name for a newly-added slot. The old WORKSPACE_LABELS array
# Default name for a slot that the user hasn't named. Slots 1–20 get
# the spelled-out cardinal (`one`, `two`, …, `twenty`); slot 21+ falls
# through to the `ws${N}` shape (which the codebase has used as a
# defensive default for years).
#
# Spelled-out cardinals are chosen for two reasons:
#   1. They preserve the ordinal-to-name mapping — knowing the slot
#      number is enough to predict the name and vice versa.
#   2. They satisfy `_validate_name_format`'s "must not start with a
#      digit" rule (since the same rule lets the workspace prompt
#      treat all-numeric input as a literal slot index).
_default_name_for_slot() {
  local slot="${1:-}"
  case "$slot" in
    1)  printf 'one' ;;
    2)  printf 'two' ;;
    3)  printf 'three' ;;
    4)  printf 'four' ;;
    5)  printf 'five' ;;
    6)  printf 'six' ;;
    7)  printf 'seven' ;;
    8)  printf 'eight' ;;
    9)  printf 'nine' ;;
    10) printf 'ten' ;;
    11) printf 'eleven' ;;
    12) printf 'twelve' ;;
    13) printf 'thirteen' ;;
    14) printf 'fourteen' ;;
    15) printf 'fifteen' ;;
    16) printf 'sixteen' ;;
    17) printf 'seventeen' ;;
    18) printf 'eighteen' ;;
    19) printf 'nineteen' ;;
    20) printf 'twenty' ;;
    *)  printf 'ws%s' "$slot" ;;
  esac
}

cmd_add() {
  _require_config
  # Flag parse: --no-prompt / -q skips interactive prompts even on a TTY.
  # Positional args are `[name] [icon]` — both optional, color is always
  # theme-derived. Old `ws add NAME COLOR ICON` callers will misbehave
  # silently (the old "color" string would now be interpreted as the
  # icon), so this is a hard CLI break.
  local no_prompt=0
  local positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-prompt|-q) no_prompt=1 ;;
      *) positional+=("$1") ;;
    esac
    shift
  done
  set -- "${positional[@]}"

  local n new_slot name icon color
  n=$(_count)
  new_slot=$((n + 1))
  name="${1:-}"
  icon="${2:-}"

  # Interactive path: TTY + no --no-prompt. Skipped under skhdrc and
  # other no-tty contexts (the hotkey wrapper opens a Ghostty window
  # so the prompts get a real terminal).
  local interactive=0
  [[ $no_prompt -eq 0 && -t 0 && -t 1 ]] && interactive=1

  if (( interactive )); then
    # Name prompt with the spelled-out default. ENTER on empty input
    # accepts the default (one, two, …, twenty, then ws${N}).
    local suggested
    suggested=$(_default_name_for_slot "$new_slot")
    if [[ -z "$name" ]]; then
      printf 'name [%s]: ' "$suggested" >&2
      read -r name
      [[ -z "$name" ]] && name="$suggested"
    fi
    # Icon prompt via fzf picker if available; ESC leaves the slot
    # icon-less (kind=none, fallbackSfSymbol="stop.fill"). Slot still
    # gets the stop.fill fallback so the pill renders.
    if [[ -z "$icon" ]] && have fzf; then
      printf 'icon: opening fzf (ESC to skip) ...\n' >&2
      icon=$(_pick_icon_fzf "icon for new slot $new_slot> " || true)
    fi
    # No color prompt: color is theme-driven via _default_color_for_slot.
  fi

  # Non-interactive fallbacks (or post-prompt defaulting if any field
  # is still unset). Color is ALWAYS derived; the user never supplies it.
  [[ -z "$name" ]] && name=$(_default_name_for_slot "$new_slot")
  color=$(_default_color_for_slot "$new_slot")
  _validate_name_format "$name"
  _validate_name_unique "$name"

  # Build a v2 iconSpec scaffold. The fallbackText is the first two chars
  # of the name uppercased (matches the seed convention in
  # spaces.default.json so post-rename slots aren't visually distinct
  # from the seeded ones in degraded renders). If an icon arg was passed,
  # resolve it now and populate kind + codepoint/symbolName.
  # `userOverridden` flips true when an icon was actually picked — the
  # paint-all.sh "bare slot" detector keys off this + stableLogicalLabel
  # to decide gray-vs-color rendering. stableLogicalLabel is set to the
  # user-supplied name so the slot starts in "customized" state and
  # gets its color shown.
  _resolve_icon_input "$icon"
  local fallback_text
  fallback_text=$(printf '%s' "${name:0:2}" | tr '[:lower:]' '[:upper:]')
  local kind="none"
  local user_overridden=false
  if [[ -n "$_ICON_SF_NAME" ]]; then
    kind="sfSymbol"
    user_overridden=true
  fi
  # Nerd Font path: user can input raw codepoint if needed for cross-platform

  # ── window manager first, spaces.json second ───────────────────────────
  # Under aerospace, workspace existence is config-time: it lives in
  # ~/.config/aerospace/aerospace.toml, not in a runtime daemon mutation.
  # `wm_create_space` always returns non-zero and prints the help text.
  # The CLI surfaces that here, then aborts before any spaces.json write
  # so identity and existence stay in sync.
  #
  # Skipped on explicit identity-only deployments (Linux harness, etc.)
  # via WS_GROW_WM_ON_ADD=0; in that case `ws add` writes the JSON only,
  # which has always been valid for non-macOS / no-WM setups.
  if [[ "${WS_GROW_WM_ON_ADD:-${WS_GROW_YABAI_ON_ADD:-1}}" == 1 ]] && _wm_available; then
    local wm_err
    if ! wm_err=$(wm_create_space 2>&1); then
      err "cannot create workspace at runtime under aerospace."
      err ""
      err "edit ~/.config/aerospace/aerospace.toml — add the workspace to"
      err "[workspace-to-monitor-force-assignment] (and any [mode.main.binding]"
      err "you want), then:"
      err "  aerospace reload-config && ws-topology emit-aerospace --write"
      err "  ws name <slot> $name${icon:+ && ws icon <slot> $icon}"
      exit 1
    fi
  fi

  _write '
    .spaces[$k] = {
      name: $n,
      color: $c,
      stableLogicalLabel: $n,
      iconSpec: (
        {
          kind: $kind,
          fallbackSfSymbol: "stop.fill",
          fallbackText: $ft,
          userOverridden: ($uo == "true")
        }
        + (if $sf != "" then {symbolName: $sf} else {} end)
        + (if $cp != "" then {codepoint: $cp} else {} end)
      )
    }
  ' --arg k "$new_slot" --arg n "$name" --arg c "$color" \
    --arg kind "$kind" --arg ft "$fallback_text" --arg uo "$user_overridden" \
    --arg cp "$_ICON_ESCAPED" --arg sf "$_ICON_SF_NAME"
  _fire_post add "$new_slot"
  _fire_cascade
}

cmd_remove() {
  _require_config
  local yes=0
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y|--yes) yes=1 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  [[ ${#args[@]} -eq 1 ]] || { err "usage: ws remove <SLOT_OR_NAME> [-y]"; exit 2; }
  local slot; slot=$(_resolve_slot "${args[0]}") || exit $?
  local n; n=$(_count)
  if (( n <= 1 )); then
    err "refusing to remove last slot (count would go to 0)"
    exit 1
  fi
  _confirm "remove slot $slot and renumber slots $((slot+1))..$n down by 1?" "$yes" \
    || { warn "aborted"; exit 1; }
  _write '
    . as $orig
    | ($orig.spaces | keys | map(tonumber) | max) as $n
    | .spaces = (
        reduce range(1; $n+1) as $i ({};
          if $i < ($slot|tonumber) then
            .[($i|tostring)] = $orig.spaces[($i|tostring)]
          elif $i == ($slot|tonumber) then
            .
          else
            .[(($i-1)|tostring)] = $orig.spaces[($i|tostring)]
          end
        )
      )
  ' --arg slot "$slot"
  _fire_post remove "$slot"
  _fire_cascade
}

cmd_swap() {
  _require_config
  [[ $# -eq 2 ]] || { err "usage: ws swap <SLOT_OR_NAME> <SLOT_OR_NAME>"; exit 2; }
  local a b
  a=$(_resolve_slot "$1") || exit $?
  b=$(_resolve_slot "$2") || exit $?
  if [[ "$a" == "$b" ]]; then return 0; fi
  # Positional fields stay anchored to the destination slot (color +
  # stableLogicalLabel). Identity fields move with the source (name +
  # iconSpec). with_entries(select(.value != null)) drops nulls so a
  # missing optional field on either side doesn't leak through as an
  # explicit null.
  _write '
    . as $orig
    | .spaces[$a] = (
        (($orig.spaces[$b] // {}) | {name, iconSpec})
        + (($orig.spaces[$a] // {}) | {color, stableLogicalLabel})
        | with_entries(select(.value != null))
      )
    | .spaces[$b] = (
        (($orig.spaces[$a] // {}) | {name, iconSpec})
        + (($orig.spaces[$b] // {}) | {color, stableLogicalLabel})
        | with_entries(select(.value != null))
      )
  ' --arg a "$a" --arg b "$b"
  _fire_post swap "$a" "$b"
  _fire_cascade
}

cmd_reorder() {
  _require_config
  local n; n=$(_count)
  if [[ $# -ne $n ]]; then
    err "reorder requires exactly $n args (current slot count); got $#"
    exit 2
  fi
  # Resolve each arg (accepts names or indices) into a normalized
  # numeric permutation. Validate: must be a permutation of 1..n.
  local resolved=()
  local i seen=""
  for (( i=1; i<=$#; i++ )); do
    local r
    r=$(_resolve_slot "${!i}") || exit $?
    if [[ ",$seen," == *",$r,"* ]]; then
      err "reorder arg $i = '${!i}' resolves to slot $r, which is a duplicate"
      exit 2
    fi
    seen="$seen,$r"
    resolved+=("$r")
  done
  local args_json
  args_json=$(printf '%s\n' "${resolved[@]}" | jq -Rn '[inputs | tonumber]')
  # Positional: color + stableLogicalLabel stay anchored to slot index.
  # Identity: name + iconSpec move with the source slot.
  _write '
    . as $orig
    | .spaces = (
        reduce range(0; ($args | length)) as $i ({};
          .[($i+1|tostring)] = (
            (($orig.spaces[($args[$i]|tostring)] // {}) | {name, iconSpec})
            + (($orig.spaces[($i+1|tostring)] // {}) | {color, stableLogicalLabel})
            | with_entries(select(.value != null))
          )
        )
      )
  ' --argjson args "$args_json"
  _fire_post reorder "${resolved[@]}"
  _fire_cascade
}

# Apply a numeric permutation array (each entry = source slot for that
# destination index, 1..N) to .spaces with positional-color semantics.
# Used by move / rotate / reverse to keep the jq path single-sourced.
_apply_perm() {
  # _apply_perm <subcommand-label> <slot1> <slot2> ... <slotN>
  local label="$1"; shift
  local n; n=$(_count)
  if [[ $# -ne $n ]]; then
    err "internal: _apply_perm got $# args, expected $n"
    exit 1
  fi
  local args_json
  args_json=$(printf '%s\n' "$@" | jq -Rn '[inputs | tonumber]')
  # Same permutation semantics as cmd_reorder: identity (name + iconSpec)
  # moves with the source slot, positional fields (color +
  # stableLogicalLabel) stay anchored to slot index.
  _write '
    . as $orig
    | .spaces = (
        reduce range(0; ($args | length)) as $i ({};
          .[($i+1|tostring)] = (
            (($orig.spaces[($args[$i]|tostring)] // {}) | {name, iconSpec})
            + (($orig.spaces[($i+1|tostring)] // {}) | {color, stableLogicalLabel})
            | with_entries(select(.value != null))
          )
        )
      )
  ' --argjson args "$args_json"
  _fire_post "$label" "$@"
  _fire_cascade
}

cmd_move() {
  _require_config
  [[ $# -ge 2 ]] || { err "usage: ws move <SRC> <DEST>  |  move <SRC> before|after <REF>"; exit 2; }
  local n; n=$(_count)
  local src; src=$(_resolve_slot "$1") || exit $?
  shift

  # Compute the 1..n list minus src ONCE; both the before|after path and
  # the numeric-dest path use it.
  local without_src=()
  local i
  for (( i=1; i<=n; i++ )); do
    [[ "$i" != "$src" ]] && without_src+=("$i")
  done

  local dest=""
  if [[ "$1" == "before" || "$1" == "after" ]]; then
    [[ $# -eq 2 ]] || { err "usage: ws move <SRC> $1 <REF>"; exit 2; }
    local direction="$1" ref
    ref=$(_resolve_slot "$2") || exit $?
    if [[ "$src" == "$ref" ]]; then return 0; fi
    local ref_pos=0
    for (( i=0; i<${#without_src[@]}; i++ )); do
      if [[ "${without_src[$i]}" == "$ref" ]]; then ref_pos=$((i+1)); break; fi
    done
    if [[ "$direction" == "before" ]]; then dest=$ref_pos; else dest=$((ref_pos + 1)); fi
  else
    [[ $# -eq 1 ]] || { err "usage: ws move <SRC> <DEST>  |  move <SRC> before|after <REF>"; exit 2; }
    if ! [[ "$1" =~ ^[1-9][0-9]*$ ]] || (( $1 < 1 )) || (( $1 > n )); then
      err "destination must be 1..$n (got: $1)"; exit 2
    fi
    dest="$1"
    if [[ "$src" == "$dest" ]]; then return 0; fi
  fi

  # Compose final permutation: without_src with src inserted at dest.
  local perm=()
  for (( i=0; i<${#without_src[@]}; i++ )); do
    if (( i+1 == dest )); then perm+=("$src"); fi
    perm+=("${without_src[$i]}")
  done
  if (( dest > ${#without_src[@]} )); then perm+=("$src"); fi
  _apply_perm move "${perm[@]}"
}

cmd_rotate() {
  _require_config
  local n; n=$(_count)
  local k="${1:-1}"
  if ! [[ "$k" =~ ^-?[0-9]+$ ]]; then err "rotate takes an integer step (got: $k)"; exit 2; fi
  # Normalize k into [0, n)
  k=$(( ((k % n) + n) % n ))
  if (( k == 0 )); then return 0; fi
  # Right rotation: new[i] = old[((i-1 - k + n) mod n) + 1]
  local perm=() i src
  for (( i=1; i<=n; i++ )); do
    src=$(( ((i - 1 - k + n) % n) + 1 ))
    perm+=("$src")
  done
  _apply_perm rotate "${perm[@]}"
}

cmd_reverse() {
  _require_config
  local n; n=$(_count)
  local perm=() i
  for (( i=n; i>=1; i-- )); do perm+=("$i"); done
  _apply_perm reverse "${perm[@]}"
}

cmd_layout() {
  _require_config
  local layouts_dir="${WS_LAYOUTS_DIR:-$HOME/.config/workspace/layouts}"
  mkdir -p "$layouts_dir"
  local sub="${1:-}"; shift || true
  case "$sub" in
    save)
      [[ $# -eq 1 ]] || { err "usage: ws layout save <NAME>"; exit 2; }
      [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]] || { err "layout name must be [A-Za-z0-9._-]+"; exit 2; }
      local dest="$layouts_dir/$1.json"
      local layout_staging; layout_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
      cp "$WS_CONFIG" "$layout_staging" && mv -f "$layout_staging" "$dest"
      ok "saved layout ${dest/#$HOME/~}"
      ;;
    load)
      local name="" yes=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -y|--yes) yes=1 ;;
          *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
        esac
        shift
      done
      [[ -n "$name" ]] || { err "usage: ws layout load <NAME> [-y]"; exit 2; }
      local src="$layouts_dir/$name.json"
      [[ -r "$src" ]] || { err "layout not found: $src"; exit 1; }
      jq -e . "$src" >/dev/null 2>&1 || { err "layout is malformed JSON: $src"; exit 1; }

      # Under aerospace, workspace existence is config-time
      # (aerospace.toml). Layout load can replace identity (spaces.json)
      # but cannot reconcile workspace count — that's a manual step.
      # When the saved layout's slot count diverges from aerospace's
      # workspace count, surface the mismatch and let the user reconcile
      # aerospace.toml first; the identity replace then completes the
      # picture.
      local saved_count current_count
      saved_count=$(jq '.spaces | length' "$src" 2>/dev/null)
      current_count=$(wm_space_count 2>/dev/null || printf '')

      if [[ "${saved_count:-}" =~ ^[0-9]+$ && "${current_count:-}" =~ ^[0-9]+$ ]]; then
        if (( saved_count < 1 )); then
          err "layout '$name' has 0 slots — refusing to load (aerospace requires ≥ 1 workspace)"
          exit 1
        fi
        if (( saved_count != current_count )); then
          err "layout '$name' has $saved_count workspaces, aerospace has $current_count."
          err "edit ~/.config/aerospace/aerospace.toml to match, then:"
          err "  aerospace reload-config && ws-topology emit-aerospace --write"
          err "  ws layout load $name"
          exit 1
        fi
        _confirm "load layout '$name' (replace spaces.json identity for $saved_count workspaces)?" "$yes" \
          || { warn "aborted"; exit 1; }
      else
        # WM unavailable or layout count unparseable — preserve the
        # legacy identity-only load behaviour.
        _confirm "replace spaces.json with layout '$name'?" "$yes" \
          || { warn "aborted"; exit 1; }
      fi

      local layout_staging; layout_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
      cp "$src" "$layout_staging" && mv -f "$layout_staging" "$WS_CONFIG"
      _fire_post layout "$name"
      _fire_cascade
      ;;
    list)
      local f
      for f in "$layouts_dir"/*.json; do
        [[ -f "$f" ]] && basename "$f" .json
      done
      ;;
    delete|rm)
      local name="" yes=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -y|--yes) yes=1 ;;
          *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
        esac
        shift
      done
      [[ -n "$name" ]] || { err "usage: ws layout delete <NAME> [-y]"; exit 2; }
      local target="$layouts_dir/$name.json"
      [[ -e "$target" ]] || { err "layout not found: $target"; exit 1; }
      _confirm "delete layout '$name'?" "$yes" || { warn "aborted"; exit 1; }
      rm -f "$target"
      ok "deleted ${target/#$HOME/~}"
      ;;
    ""|-h|--help|help)
      cat <<'EOF_LAYOUT'
ws layout — save / load / list named snapshots of spaces.json

  ws layout save <NAME>          snapshot current state
  ws layout load <NAME> [-y]     restore a saved snapshot
  ws layout list                 list saved layouts
  ws layout delete <NAME> [-y]   remove a saved layout

Layouts are stored in ~/.config/workspace/layouts/<NAME>.json (or
$WS_LAYOUTS_DIR if set). They are per-machine and not committed.
EOF_LAYOUT
      ;;
    *)
      err "unknown layout subcommand: $sub"; exit 2 ;;
  esac
}

cmd_theme() {
  _require_config
  local name="" with_icons=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --with-icons) with_icons=1 ;;
      -*) err "unknown flag: $1"; exit 2 ;;
      *) [[ -z "$name" ]] && name="$1" || { err "unexpected arg: $1"; exit 2; } ;;
    esac
    shift
  done
  [[ -n "$name" ]] || { err "usage: ws theme <NAME> [--with-icons]"; exit 2; }
  local theme_file="$WS_THEMES_DIR/$name.json"
  [[ -r "$theme_file" ]] || { err "theme not found: $theme_file"; exit 1; }
  jq -e . "$theme_file" >/dev/null 2>&1 || { err "theme is malformed JSON: $theme_file"; exit 1; }

  local n; n=$(_count)
  local apply_icons="false"
  (( with_icons )) && apply_icons="true"

  # Pre-resolve theme icons (when --with-icons) into a parallel array of
  # ASCII-escaped codepoints, so jq can patch iconSpec.codepoint per slot
  # without forking _resolve_icon_input mid-reduce. The theme file stores
  # icons as raw glyph strings; we round-trip through _resolve_icon_input
  # to get the same `\uXXXX`/`\u{XXXXX}` form spaces.json uses.
  local theme_icons_json="[]"
  if (( with_icons )); then
    local raw_icons=()
    mapfile -t raw_icons < <(jq -r '.icons // [] | .[]' "$theme_file")
    local escaped=()
    local raw
    for raw in "${raw_icons[@]}"; do
      if [[ -z "$raw" ]]; then
        escaped+=("")
      else
        _resolve_icon_input "$raw"
        escaped+=("$_ICON_ESCAPED")
      fi
    done
    theme_icons_json=$(printf '%s\n' "${escaped[@]:-}" | jq -R . | jq -s .)
  fi

  _write '
    . as $orig
    | ($theme[0].colors // []) as $tc
    | ($n | tonumber) as $count
    | ($icons | length) as $ni
    | .spaces = (
        reduce range(1; $count+1) as $i ($orig.spaces;
          .[($i|tostring)] = (
            (.[($i|tostring)] // {}) as $s
            | $s
            + (if ($tc | length) >= $i then {color: $tc[$i-1]} else {} end)
            + (
                if ($apply_icons == "true") and $ni >= $i and ($icons[$i-1] // "") != "" then
                  { iconSpec: (
                      {
                        kind: "nerdFont",
                        fallbackSfSymbol: ($s.iconSpec.fallbackSfSymbol // "stop.fill"),
                        fallbackText: ($s.iconSpec.fallbackText // (($s.name // "") | .[0:2] | ascii_upcase)),
                        userOverridden: false,
                        codepoint: $icons[$i-1],
                        fontFamily: "JetBrainsMono Nerd Font"
                      }
                  )}
                else {} end
              )
          )
        )
      )
    | .palette = $name
  ' --slurpfile theme "$theme_file" \
    --arg n "$n" --arg apply_icons "$apply_icons" --arg name "$name" \
    --argjson icons "$theme_icons_json"
  _fire_post theme
  _fire_cascade
}

cmd_edit() {
  _require_config
  local editor="${EDITOR:-vi}"
  "$editor" "$WS_CONFIG"
  if ! jq -e . "$WS_CONFIG" >/dev/null 2>&1; then
    err "spaces.json is now malformed; refusing to fire cascade (fix the file or run 'ws reset')"
    exit 1
  fi
  _fire_post edit
  _fire_cascade
}

cmd_reset() {
  local yes=0
  [[ "${1:-}" == "-y" || "${1:-}" == "--yes" ]] && yes=1
  [[ -r "$WS_DEFAULTS" ]] || { err "defaults file not found: $WS_DEFAULTS"; exit 1; }
  _confirm "reset spaces.json to defaults from $WS_DEFAULTS?" "$yes" \
    || { warn "aborted"; exit 1; }
  local defaults_staging; defaults_staging=$(mktemp) || { err "mktemp failed"; exit 1; }
  cp -f "$WS_DEFAULTS" "$defaults_staging"
  jq -e . "$defaults_staging" >/dev/null 2>&1 || { rm -f "$defaults_staging"; err "defaults file is malformed"; exit 1; }
  mv -f "$defaults_staging" "$WS_CONFIG"
  _fire_post reset
  _fire_cascade
}

cmd_doctor() {
  if [[ ! -r "$WS_CONFIG" ]]; then
    err "spaces.json not found: $WS_CONFIG"
    return 1
  fi
  if ! jq -e . "$WS_CONFIG" >/dev/null 2>&1; then
    err "spaces.json is not valid JSON"
    return 1
  fi
  local bad=0
  # Schema invariants:
  #   - slot keys are contiguous 1..count
  #   - name (string) + color (#RRGGBB string)
  #   - iconSpec is optional; when absent it is read as {kind: "none"}.
  #     Present-but-malformed (wrong type, unknown kind, missing
  #     codepoint/symbolName) is still flagged.
  #   - kind=nerdFont implies codepoint (string)
  #   - kind=sfSymbol implies symbolName (string)
  #   - userOverridden is boolean
  local report
  report=$(jq -r '
    .spaces as $s
    | ($s | keys | map(tonumber) | sort) as $ks
    | [ ($ks | length) as $n
      | $ks | to_entries[]
      | select(.value != (.key + 1))
      | "gap: expected slot \(.key + 1), found \(.value)"
      ] + [
        $s | to_entries[]
        | select(
            (.value.name | type) != "string" or
            (.value.color | type) != "string"
          )
        | "slot \(.key): missing/wrong type for name|color"
      ] + [
        $s | to_entries[]
        | select((.value.color // "") | test("^#[0-9a-fA-F]{6}$") | not)
        | "slot \(.key): color \"\(.value.color)\" is not #RRGGBB"
      ] + [
        # iconSpec is optional. Flag only when it is present AND not an
        # object — missing iconSpec is implicit kind=none.
        $s | to_entries[]
        | select(.value.iconSpec != null and (.value.iconSpec | type) != "object")
        | "slot \(.key): iconSpec is present but not an object"
      ] + [
        $s | to_entries[]
        | select(.value.iconSpec | type == "object")
        | select((.value.iconSpec.kind // "") as $k | $k != "sfSymbol" and $k != "nerdFont" and $k != "none")
        | "slot \(.key): iconSpec.kind \"\(.value.iconSpec.kind)\" must be sfSymbol|nerdFont|none"
      ] + [
        # Object-type guard prevents jq from erroring on indexing a
        # non-object iconSpec (which is already reported above).
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select(.value.iconSpec.kind == "nerdFont")
        | select((.value.iconSpec.codepoint // "") == "" or (.value.iconSpec.codepoint | type) != "string")
        | "slot \(.key): kind=nerdFont but codepoint missing"
      ] + [
        $s | to_entries[]
        | select((.value.iconSpec | type) == "object")
        | select(.value.iconSpec.kind == "sfSymbol")
        | select((.value.iconSpec.symbolName // "") == "" or (.value.iconSpec.symbolName | type) != "string")
        | "slot \(.key): kind=sfSymbol but symbolName missing"
      ] + [
        $s | to_entries[]
        | select(.value.iconSpec | type == "object")
        | select(.value.iconSpec.userOverridden != null and (.value.iconSpec.userOverridden | type) != "boolean")
        | "slot \(.key): iconSpec.userOverridden must be boolean"
      ]
    | .[]
  ' "$WS_CONFIG" 2>/dev/null) || bad=1
  if [[ -n "$report" ]]; then
    while IFS= read -r line; do
      err "$line"
    done <<<"$report"
    bad=1
  fi
  # Soft-warn on duplicate names.
  local dups
  dups=$(jq -r '
    [.spaces[].name] | group_by(.) | map(select(length > 1) | .[0]) | .[]
  ' "$WS_CONFIG" 2>/dev/null)
  if [[ -n "$dups" ]]; then
    while IFS= read -r name; do
      warn "duplicate name: $name"
    done <<<"$dups"
  fi
  # Drift check: spaces.json should never have more entries than
  # aerospace has workspaces. Under aerospace, workspace count is
  # config-time (aerospace.toml), so drift means the user added a
  # spaces.json entry without declaring the corresponding workspace —
  # orphans accumulate and block `ws name` uniqueness checks against
  # ghost slots. WS_SKIP_WM_SLOT_CHECK=1 (alias: WS_SKIP_YABAI_SLOT_CHECK)
  # disables every WM-derived bound (this drift check +
  # _resolve_slot's addressable bound + cmd_count's view). Set by the
  # verify harness, which intentionally grows the JSON beyond aerospace's
  # real workspace count to give positional tests headroom.
  if [[ "${WS_SKIP_WM_SLOT_CHECK:-${WS_SKIP_YABAI_SLOT_CHECK:-0}}" != "1" ]] \
       && _wm_available; then
    local wm_n json_n
    wm_n=$(wm_space_count 2>/dev/null || echo 0)
    json_n=$(jq '.spaces | length' "$WS_CONFIG" 2>/dev/null || echo 0)
    if (( json_n > wm_n )); then
      warn "drift: spaces.json has $json_n slots, aerospace has $wm_n. Orphan slots $((wm_n + 1))..$json_n won't render but will block name-uniqueness. Fix: declare them in ~/.config/aerospace/aerospace.toml + reload-config, or run \`ws remove $((wm_n + 1))..$json_n\` to drop identity."
      bad=1
    fi
  fi
  if (( bad )); then
    return 1
  fi
  ok "spaces.json schema OK ($( _count ) slots)"
}

cmd_verify() {
  local harness="$HOME/.config/workspace/cli/test-cascade.sh"
  if [[ ! -x "$harness" ]]; then
    harness="$DOTFILES_DIR/configs/workspace/cli/test-cascade.sh"
  fi
  if [[ ! -x "$harness" ]]; then
    err "test-cascade.sh not found (re-run bootstrap?)"
    exit 1
  fi
  exec "$harness" "$@"
}

# ── dispatch ────────────────────────────────────────────────────────────

case "${1:-}" in
  ""|-h|--help|help) cmd_help ;;
  status)            shift; cmd_status   "$@" ;;
  get)               shift; cmd_get      "$@" ;;
  count)             shift; cmd_count    "$@" ;;
  themes)            shift; cmd_themes   "$@" ;;
  name)              shift; cmd_name     "$@" ;;
  icon)              shift; cmd_icon     "$@" ;;
  add)               shift; cmd_add      "$@" ;;
  remove)            shift; cmd_remove   "$@" ;;
  swap)              shift; cmd_swap     "$@" ;;
  move)              shift; cmd_move     "$@" ;;
  rotate)            shift; cmd_rotate   "$@" ;;
  reverse)           shift; cmd_reverse  "$@" ;;
  reorder)           shift; cmd_reorder  "$@" ;;
  theme)             shift; cmd_theme    "$@" ;;
  edit)              shift; cmd_edit     "$@" ;;
  reset)             shift; cmd_reset    "$@" ;;
  doctor)            shift; cmd_doctor   "$@" ;;
  verify)            shift; cmd_verify   "$@" ;;
  layout)            shift; cmd_layout   "$@" ;;
  migrate)           shift; cmd_migrate  "$@" ;;
  host)              shift; cmd_host     "$@" ;;
  refresh)           shift; cmd_refresh  "$@" ;;
  *) err "unknown subcommand: $1 (try 'ws --help')"; exit 2 ;;
esac
